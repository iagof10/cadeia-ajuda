@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthStateService AuthState
@implements IDisposable

<!-- BEGIN: Header-->
<nav class="header-navbar navbar-expand-md navbar navbar-with-menu navbar-without-dd-arrow fixed-top navbar-light navbar-shadow navbar-brand-center">
    <div class="navbar-wrapper">
        <div class="navbar-header">
            <ul class="nav navbar-nav flex-row">
                <li class="nav-item mobile-menu d-md-none mr-auto">
                    <a class="nav-link nav-menu-main menu-toggle hidden-xs" href="javascript:void(0)"><i class="ft-menu font-large-1"></i></a>
                </li>
                <li class="nav-item">
                    <NavLink class="navbar-brand" href="/dashboard">
                        <img class="brand-logo" alt="Cadeia Ajuda logo" src="app-assets/images/logo/AssistChain-logo.png">
                    </NavLink>
                </li>
                <li class="nav-item d-md-none">
                    <a class="nav-link open-navbar-container" href="javascript:void(0)" data-toggle="collapse" data-target="#navbar-mobile"><i class="la la-ellipsis-v"></i></a>
                </li>
            </ul>
        </div>
        <div class="navbar-container content">
            <div class="collapse navbar-collapse" id="navbar-mobile">
                <ul class="nav navbar-nav mr-auto float-left">
                    <li class="nav-item d-none d-md-block">
                        <a class="nav-link nav-menu-main menu-toggle hidden-xs" href="javascript:void(0)"><i class="ft-menu"></i></a>
                    </li>
                    <li class="nav-item d-none d-lg-block">
                        <a class="nav-link nav-link-expand" href="javascript:void(0)" onclick="toggleFullScreen()"><i class="ficon ft-maximize"></i></a>
                    </li>
                </ul>
                <ul class="nav navbar-nav float-right">
                    <li class="dropdown dropdown-user nav-item">
                        <a class="dropdown-toggle nav-link dropdown-user-link" href="javascript:void(0)" data-toggle="dropdown">
                            <span class="mr-1 user-name text-bold-700">@currentUserName</span>
                            <span class="user-initials-badge">@userInitials</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item text-danger" href="/auth/logout"><i class="ft-power"></i> Sair</a>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>
<!-- END: Header-->

<!-- BEGIN: Main Menu-->
<div class="main-menu menu-fixed menu-light menu-accordion menu-shadow" data-scroll-to-active="true">
    <div class="main-menu-content">
        <ul class="navigation navigation-main" id="main-menu-navigation" data-menu="menu-navigation">
            @if (!isAndonUser && HasPermission("dashboard.view"))
            {
                <li class="nav-item @(IsActive("/dashboard") ? "active" : "")">
                    <NavLink href="/dashboard">
                        <i class="ft-pie-chart"></i>
                        <span class="menu-title">Dashboard</span>
                    </NavLink>
                </li>
            }
            @if (!isAndonUser && HasAnyPermission("help_request_types.view", "reasons.view", "sectors.view", "areas.view", "escalation.view"))
            {
                <li class="nav-item @(IsActive("/register/help-request-types") || IsActive("/register/reasons") || IsActive("/register/sectors") || IsActive("/register/plants") || IsActive("/register/escalation") ? "active" : "")">
                    <a href="javascript:void(0)">
                        <i class="ft-file-plus"></i>
                        <span class="menu-title">Cadastro</span>
                    </a>
                    <ul class="menu-content">
                        @if (HasPermission("help_request_types.view"))
                        {
                            <li class="@(IsActive("/register/help-request-types") ? "active" : "")">
                                <NavLink class="menu-item" href="/register/help-request-types" Match="NavLinkMatch.Prefix">
                                    <i class="ft-flag"></i>
                                    <span>Tipo de Ajuda</span>
                                </NavLink>
                            </li>
                        }
                        @if (HasPermission("reasons.view"))
                        {
                            <li class="@(IsActive("/register/reasons") ? "active" : "")">
                                <NavLink class="menu-item" href="/register/reasons" Match="NavLinkMatch.Prefix">
                                    <i class="ft-tag"></i>
                                    <span>Motivo</span>
                                </NavLink>
                            </li>
                        }
                        @if (HasPermission("sectors.view"))
                        {
                            <li class="@(IsActive("/register/sectors") ? "active" : "")">
                                <NavLink class="menu-item" href="/register/sectors" Match="NavLinkMatch.Prefix">
                                    <i class="ft-compass"></i>
                                    <span>Setor</span>
                                </NavLink>
                            </li>
                        }
                        @if (HasPermission("areas.view"))
                        {
                            <li class="@(IsActive("/register/plants") ? "active" : "")">
                                <NavLink class="menu-item" href="/register/plants" Match="NavLinkMatch.Prefix" data-enhance-nav="false">
                                    <i class="la la-sitemap"></i>
                                    <span>Planta</span>
                                </NavLink>
                            </li>
                        }
                        @if (HasPermission("escalation.view"))
                        {
                            <li class="@(IsActive("/register/escalation") ? "active" : "")">
                                <NavLink class="menu-item" href="/register/escalation-levels" Match="NavLinkMatch.Prefix" data-enhance-nav="false">
                                    <i class="ft-award"></i>
                                    <span>Escalonamento</span>
                                </NavLink>
                            </li>
                        }
                    </ul>
                </li>
            }
            @if (!isAndonUser && HasAnyPermission("help_requests.view", "help_requests.close"))
            {
                <li class="nav-item @(IsActive("/help-requests") ? "active" : "")">
                    <a href="javascript:void(0)">
                        <i class="ft-phone"></i>
                        <span class="menu-title">Chamado</span>
                    </a>
                    <ul class="menu-content">
                        @if (HasPermission("help_requests.view"))
                        {
                            <li class="@((IsActive("/help-requests") && !IsActive("/help-requests/close")) ? "active" : "")">
                                <NavLink class="menu-item" href="/help-requests" Match="NavLinkMatch.All" data-enhance-nav="false">
                                    <i class="ft-phone-forwarded"></i>
                                    <span>Cadeia de Ajuda</span>
                                </NavLink>
                            </li>
                        }
                        @if (HasPermission("help_requests.close"))
                        {
                            <li class="@(IsActive("/help-requests/close") ? "active" : "")">
                                <NavLink class="menu-item" href="/help-requests/close" Match="NavLinkMatch.All" data-enhance-nav="false">
                                    <i class="ft-phone-missed"></i>
                                    <span>Encerrar Ajuda</span>
                                </NavLink>
                            </li>
                        }
                    </ul>
                </li>
            }
            @if (isAndonUser && HasPermission("andon.view"))
            {
                <li class="nav-item @(IsActive("/andon") ? "active" : "")">
                    <NavLink href="/andon" Match="NavLinkMatch.Prefix" data-enhance-nav="false">
                        <i class="ft-monitor"></i>
                        <span class="menu-title">Andon</span>
                    </NavLink>
                </li>
            }
            @if (!isAndonUser && HasAnyPermission("users.view", "roles.view"))
            {
                <li class="nav-item @(IsActive("/user/users") || IsActive("/user/roles") ? "active" : "")">
                    <a href="javascript:void(0)">
                        <i class="la la-user"></i>
                        <span class="menu-title">Usuário</span>
                    </a>
                    <ul class="menu-content">
                        @if (HasPermission("users.view"))
                        {
                            <li class="@(IsActive("/user/users") ? "active" : "")">
                                <NavLink class="menu-item" href="/user/users" Match="NavLinkMatch.Prefix">
                                    <i class="ft-users"></i>
                                    <span>Usuário</span>
                                </NavLink>
                            </li>
                        }
                        @if (HasPermission("roles.view"))
                        {
                            <li class="@(IsActive("/user/roles") ? "active" : "")">
                                <NavLink class="menu-item" href="/user/roles" Match="NavLinkMatch.Prefix" data-enhance-nav="false">
                                    <i class="ft-pocket"></i>
                                    <span>Perfil</span>
                                </NavLink>
                            </li>
                        }
                    </ul>
                </li>
            }
            @if (!isAndonUser && HasPermission("reports.view"))
            {
                <li class="nav-item @(IsActive("/reports") ? "active" : "")">
                    <NavLink href="/reports" Match="NavLinkMatch.Prefix">
                        <i class="ft-bar-chart-2"></i>
                        <span class="menu-title">Relatório</span>
                    </NavLink>
                </li>
            }
            @if (!isAndonUser && HasPermission("company.view"))
            {
                <li class="nav-item @(IsActive("/settings") ? "active" : "")">
                    <NavLink href="/settings/company" Match="NavLinkMatch.Prefix">
                        <i class="ft-settings"></i>
                        <span class="menu-title">Configuração</span>
                    </NavLink>
                </li>
            }
        </ul>
    </div>
</div>
<!-- END: Main Menu-->

<!-- BEGIN: Content-->
<div class="app-content content">
    <div class="content-overlay"></div>
    <div class="content-wrapper">
        <div class="content-header row">
        </div>
        <div class="content-body">
            @Body
        </div>
    </div>
</div>
<!-- END: Content-->

<div class="sidenav-overlay"></div>
<div class="drag-target"></div>

<!-- BEGIN: Footer-->
<footer class="footer footer-static footer-light navbar-border navbar-shadow">
    <p class="clearfix blue-grey lighten-2 text-sm-center mb-0 px-2">
        <span class="float-md-left d-block d-md-inline-block">Copyright &copy; @DateTime.Now.Year <a class="text-bold-800 grey darken-2" href="javascript:void(0)">Cadeia Ajuda</a></span>
        <span class="float-md-right d-none d-lg-block">Painel Administrativo</span>
    </p>
</footer>
<!-- END: Footer-->

<style>
    .navbar-header {
        width: 240px;
    }

    .navbar-header .navbar-brand .brand-logo {
        height: 50px !important;
        width: auto !important;
        max-width: none !important;
        object-fit: contain;
        display: block;
        transform: translateY(-6px);
    }

    .user-initials-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        color: #fff;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        line-height: 1;
    }

    /* Page titles: orange */
    .content-header-title,
    .card-header .card-title {
        color: #f57c00 !important;
    }

    /* Menu active state: orange instead of blue */
    .main-menu .navigation > li.active > a {
        color: #f57c00 !important;
        background: linear-gradient(118deg, rgba(245,124,0,.2), rgba(245,124,0,.01)) !important;
    }

    .main-menu .navigation > li.active > a > i {
        color: #f57c00 !important;
    }

    .main-menu .navigation li.active > a .menu-title {
        color: #f57c00 !important;
    }

    .main-menu .navigation li .menu-content li.active > a {
        color: #f57c00 !important;
    }

    .main-menu .navigation > li.active > a::before,
    .main-menu .navigation > li.active > a::after {
        background: #f57c00 !important;
    }

    .main-menu .navigation > li.open > a,
    .main-menu .navigation > li.menu-collapsed-open > a,
    .main-menu .navigation > li.active > a,
    .main-menu .navigation > li.hover > a,
    .main-menu .navigation > li:hover > a,
    .vertical-compact-menu .main-menu .navigation > li.active > a,
    .vertical-compact-menu .main-menu .navigation > li.open > a,
    .vertical-compact-menu .main-menu .navigation > li.hover > a {
        border-right-color: #f57c00 !important;
    }

    .main-menu .navigation > li ul .active {
        background: transparent !important;
    }

    .main-menu .navigation > li ul .active > a {
        color: #f57c00 !important;
    }
</style>

@code {
private string currentUrl = string.Empty;
private string currentUserName = "";
private string userInitials = "";
private string tenantIdentifier = "";
private List<string> permissions = [];
private bool isAndonUser;
private bool isAdmin;

protected override void OnInitialized()
{
    currentUrl = GetRelativePath();
    Navigation.LocationChanged += OnLocationChanged;

    var user = AuthState.GetCurrentUser();
    if (user is not null)
    {
        currentUserName = user.Name;
        tenantIdentifier = user.TenantIdentifier;
        userInitials = GetInitials(user.Name);
        permissions = user.Permissions ?? [];
        isAndonUser = user.UserType == UserType.Andon;
        isAdmin = user.UserType == UserType.Administrator;
    }
}

private bool HasPermission(string key)
{
    if (isAdmin) return true;
    return permissions.Contains(key);
}

private bool HasAnyPermission(params string[] keys)
{
    if (isAdmin) return true;
    return keys.Any(k => permissions.Contains(k));
}

private static string GetInitials(string name)
{
    var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length == 0) return "?";
    if (parts.Length == 1) return parts[0][..1].ToUpper();
    return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
}

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        currentUrl = GetRelativePath();
        InvokeAsync(StateHasChanged);
    }

    private string GetRelativePath()
    {
        return new Uri(Navigation.Uri).AbsolutePath;
    }

    private bool IsActive(string path)
    {
        return currentUrl.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}












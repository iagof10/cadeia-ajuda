@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthStateService AuthState
@implements IDisposable

<!-- BEGIN: Header-->
<nav class="header-navbar navbar-expand-md navbar navbar-with-menu navbar-without-dd-arrow fixed-top navbar-light navbar-shadow navbar-brand-center">
    <div class="navbar-wrapper">
        <div class="navbar-header">
            <ul class="nav navbar-nav flex-row">
                <li class="nav-item mobile-menu d-md-none mr-auto">
                    <a class="nav-link nav-menu-main menu-toggle hidden-xs" href="javascript:void(0)"><i class="ft-menu font-large-1"></i></a>
                </li>
                <li class="nav-item">
                    <NavLink class="navbar-brand" href="/admin/dashboard">
                        <img class="brand-logo" alt="Cadeia Ajuda logo" src="app-assets/images/logo/logo.png">
                        <h3 class="brand-text">Cadeia Ajuda</h3>
                    </NavLink>
                </li>
                <li class="nav-item d-md-none">
                    <a class="nav-link open-navbar-container" href="javascript:void(0)" data-toggle="collapse" data-target="#navbar-mobile"><i class="la la-ellipsis-v"></i></a>
                </li>
            </ul>
        </div>
        <div class="navbar-container content">
            <div class="collapse navbar-collapse" id="navbar-mobile">
                <ul class="nav navbar-nav mr-auto float-left">
                    <li class="nav-item d-none d-md-block">
                        <a class="nav-link nav-menu-main menu-toggle hidden-xs" href="javascript:void(0)"><i class="ft-menu"></i></a>
                    </li>
                    <li class="nav-item d-none d-lg-block">
                        <a class="nav-link nav-link-expand" href="javascript:void(0)" onclick="toggleFullScreen()"><i class="ficon ft-maximize"></i></a>
                    </li>
                </ul>
                <ul class="nav navbar-nav float-right">
                    <li class="dropdown dropdown-notification nav-item">
                        <a class="nav-link nav-link-label" href="javascript:void(0)" data-toggle="dropdown">
                            <i class="ficon ft-bell"></i>
                            <span class="badge badge-pill badge-danger badge-up badge-glow">5</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-media dropdown-menu-right">
                            <li class="dropdown-menu-header">
                                <h6 class="dropdown-header m-0"><span class="grey darken-2">Notificaçőes</span></h6>
                                <span class="notification-tag badge badge-danger float-right m-0">5 Novas</span>
                            </li>
                            <li class="scrollable-container media-list w-100">
                                <a href="javascript:void(0)">
                                    <div class="media">
                                        <div class="media-left align-self-center"><i class="ft-plus-square icon-bg-circle bg-cyan mr-0"></i></div>
                                        <div class="media-body">
                                            <h6 class="media-heading">Novo chamado recebido!</h6>
                                            <p class="notification-text font-small-3 text-muted">Um novo chamado foi aberto.</p>
                                            <small><time class="media-meta text-muted">30 minutos atrás</time></small>
                                        </div>
                                    </div>
                                </a>
                            </li>
                            <li class="dropdown-menu-footer">
                                <a class="dropdown-item text-muted text-center" href="javascript:void(0)">Ver todas as notificaçőes</a>
                            </li>
                        </ul>
                    </li>
                    <li class="dropdown dropdown-user nav-item">
                        <a class="dropdown-toggle nav-link dropdown-user-link" href="javascript:void(0)" data-toggle="dropdown">
                            <span class="mr-1 user-name text-bold-700">@currentUserName</span>
                            <span class="user-initials-badge">@userInitials</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" href="javascript:void(0)"><i class="ft-user"></i> Perfil</a>
                            <div class="dropdown-divider"></div>
                            <button type="button" class="dropdown-item text-danger" @onclick="Logout"><i class="ft-power"></i> Sair</button>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>
<!-- END: Header-->

<!-- BEGIN: Main Menu-->
<div class="main-menu menu-fixed menu-light menu-accordion menu-shadow" data-scroll-to-active="true">
    <div class="main-menu-content">
        <ul class="navigation navigation-main" id="main-menu-navigation" data-menu="menu-navigation">
            <li class="nav-item @(IsActive("/admin/dashboard") ? "active" : "")">
                <NavLink href="/admin/dashboard">
                    <i class="la la-home"></i>
                    <span class="menu-title">Dashboard</span>
                </NavLink>
            </li>
            <li class="nav-item @(IsActive("/admin/tenants") ? "active" : "")">
                <NavLink href="/admin/tenants" Match="NavLinkMatch.Prefix">
                    <i class="la la-building"></i>
                    <span class="menu-title">Empresas</span>
                </NavLink>
            </li>
            <li class="nav-item @(IsActive("/admin/users") || IsActive("/admin/roles") ? "active" : "")">
                <a href="javascript:void(0)">
                    <i class="la la-users"></i>
                    <span class="menu-title">Usuários</span>
                </a>
                <ul class="menu-content">
                    <li class="@(IsActive("/admin/users") ? "active" : "")">
                        <NavLink class="menu-item" href="/admin/users" Match="NavLinkMatch.Prefix">
                            <i class="la la-user"></i>
                            <span>Usuários</span>
                        </NavLink>
                    </li>
                    <li class="@(IsActive("/admin/roles") ? "active" : "")">
                        <NavLink class="menu-item" href="/admin/roles" Match="NavLinkMatch.Prefix">
                            <i class="la la-shield"></i>
                            <span>Perfis</span>
                        </NavLink>
                    </li>
                </ul>
            </li>
            <li class="nav-item @(IsActive("/admin/sectors") || IsActive("/admin/escalation-levels") ? "active" : "")">
                <a href="javascript:void(0)">
                    <i class="la la-sitemap"></i>
                    <span class="menu-title">Setores</span>
                </a>
                <ul class="menu-content">
                    <li class="@(IsActive("/admin/sectors") ? "active" : "")">
                        <NavLink class="menu-item" href="/admin/sectors" Match="NavLinkMatch.Prefix">
                            <i class="la la-sitemap"></i>
                            <span>Setores</span>
                        </NavLink>
                    </li>
                    <li class="@(IsActive("/admin/escalation-levels") ? "active" : "")">
                        <NavLink class="menu-item" href="/admin/escalation-levels" Match="NavLinkMatch.Prefix">
                            <i class="la la-level-up"></i>
                            <span>Escalonamento</span>
                        </NavLink>
                    </li>
                </ul>
            </li>
            <li class="nav-item @(IsActive("/admin/areas") ? "active" : "")">
                <NavLink href="/admin/areas" Match="NavLinkMatch.Prefix">
                    <i class="la la-cubes"></i>
                    <span class="menu-title">Áreas</span>
                </NavLink>
            </li>
            <li class="nav-item @(IsActive("/admin/locations") ? "active" : "")">
                <NavLink href="/admin/locations" Match="NavLinkMatch.Prefix">
                    <i class="la la-map-marker"></i>
                    <span class="menu-title">Localizaçőes</span>
                </NavLink>
            </li>
            <li class="nav-item @(IsActive("/admin/help-request-types") || IsActive("/admin/priorities") || IsActive("/admin/settings") ? "active" : "")">
                <a href="javascript:void(0)">
                    <i class="la la-cog"></i>
                    <span class="menu-title">Configuraçőes</span>
                </a>
                <ul class="menu-content">
                    <li class="@(IsActive("/admin/help-request-types") ? "active" : "")">
                        <NavLink class="menu-item" href="/admin/help-request-types" Match="NavLinkMatch.Prefix">
                            <i class="la la-question-circle"></i>
                            <span>Tipos de Solicitaçăo</span>
                        </NavLink>
                    </li>
                    <li class="@(IsActive("/admin/priorities") ? "active" : "")">
                        <NavLink class="menu-item" href="/admin/priorities" Match="NavLinkMatch.Prefix">
                            <i class="la la-flag"></i>
                            <span>Prioridades</span>
                        </NavLink>
                    </li>
                    <li class="@(IsActive("/admin/settings") ? "active" : "")">
                        <NavLink class="menu-item" href="/admin/settings" Match="NavLinkMatch.Prefix">
                            <i class="la la-sliders"></i>
                            <span>Geral</span>
                        </NavLink>
                    </li>
                </ul>
            </li>
        </ul>
    </div>
</div>
<!-- END: Main Menu-->

<!-- BEGIN: Content-->
<div class="app-content content">
    <div class="content-overlay"></div>
    <div class="content-wrapper">
        <div class="content-header row">
        </div>
        <div class="content-body">
            @Body
        </div>
    </div>
</div>
<!-- END: Content-->

<div class="sidenav-overlay"></div>
<div class="drag-target"></div>

<!-- BEGIN: Footer-->
<footer class="footer footer-static footer-light navbar-border navbar-shadow">
    <p class="clearfix blue-grey lighten-2 text-sm-center mb-0 px-2">
        <span class="float-md-left d-block d-md-inline-block">Copyright &copy; @DateTime.Now.Year <a class="text-bold-800 grey darken-2" href="javascript:void(0)">Cadeia Ajuda</a></span>
        <span class="float-md-right d-none d-lg-block">Painel Administrativo</span>
    </p>
</footer>
<!-- END: Footer-->

<style>
    .user-initials-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1e9ff2 0%, #1565c0 100%);
        color: #fff;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        line-height: 1;
    }
</style>

@code {
private string currentUrl = string.Empty;
private string currentUserName = "";
private string userInitials = "";
private string tenantIdentifier = "";

protected override void OnInitialized()
{
    currentUrl = GetRelativePath();
    Navigation.LocationChanged += OnLocationChanged;

    var user = AuthState.GetCurrentUser();
    if (user is not null)
    {
        currentUserName = user.Name;
        tenantIdentifier = user.TenantIdentifier;
        userInitials = GetInitials(user.Name);
    }
}

private static string GetInitials(string name)
{
    var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length == 0) return "?";
    if (parts.Length == 1) return parts[0][..1].ToUpper();
    return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
}

private void Logout()
{
    var identifier = tenantIdentifier;
    AuthState.Clear();
    Navigation.NavigateTo($"/login/{identifier}", forceLoad: true);
}

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        currentUrl = GetRelativePath();
        InvokeAsync(StateHasChanged);
    }

    private string GetRelativePath()
    {
        return new Uri(Navigation.Uri).AbsolutePath;
    }

    private bool IsActive(string path)
    {
        return currentUrl.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
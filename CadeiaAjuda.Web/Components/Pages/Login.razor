@page "/login/{Identifier}"
@layout LoginLayout
@inject AuthStateService Auth
@inject NavigationManager Navigation

<PageTitle>Login - Cadeia Ajuda</PageTitle>

<div class="auth-wrapper">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <img src="app-assets/images/logo/AssistChain-logo-2.png" alt="AssistChain" class="brand-logo-full" />
            </div>
            <h1>Gerencie suas operações com agilidade</h1>
            <p>Plataforma completa para gestão de cadeia de ajuda, chamados e escalonamento em tempo real.</p>
            <div class="auth-left-shapes">
                <div class="shape shape-1"></div>
                <div class="shape shape-2"></div>
                <div class="shape shape-3"></div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-wrapper">
            <div class="auth-form-header">
                <div class="auth-mobile-brand d-lg-none">
                    <img src="app-assets/images/logo/AssistChain-logo.png" alt="AssistChain" class="brand-logo-mobile" />
                </div>
                <h2>Bem-vindo de volta!</h2>
                <p class="text-muted">Faça login para acessar sua conta</p>
            </div>

            <form method="post" action="/auth/do-login" id="loginForm">
                <input type="hidden" name="TenantIdentifier" value="@Identifier" />

                <div class="auth-field">
                    <label>Login</label>
                    <div class="auth-input-group">
                        <i class="la la-user"></i>
                        <input type="text" name="Login" id="loginField" class="form-control" placeholder="Seu login de acesso" required />
                    </div>
                </div>

                <div class="auth-field">
                    <label>Senha</label>
                    <div class="auth-input-group">
                        <i class="la la-lock"></i>
                        <input type="password" name="Password" id="passwordField" class="form-control" placeholder="Sua senha" required />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="auth-error">
                        <i class="la la-exclamation-circle"></i> @ErrorMessage
                    </div>
                }

                <div id="loginError" class="auth-error" style="display:none;"></div>

                <button type="submit" class="btn-auth-submit" id="btnSubmit">
                    <span id="btnText">Entrar</span>
                    <i class="ft-arrow-right" id="btnIcon"></i>
                </button>
            </form>

            <div class="auth-footer">
                <a href="/">
                    <i class="ft-arrow-left"></i> Trocar empresa
                </a>
            </div>
        </div>
    </div>
</div>

<div class="session-modal-overlay" id="sessionModal" style="display:none;">
    <div class="session-modal">
        <div class="session-modal-icon">
            <i class="la la-exclamation-triangle"></i>
        </div>
        <h3>Sessão ativa detectada</h3>
        <p>Este usuário já possui uma sessão ativa em outro dispositivo. Ao continuar, a sessão anterior será encerrada.</p>
        <p class="text-muted" style="font-size: 0.85rem;">Deseja desconectar a outra sessão e entrar aqui?</p>
        <div class="session-modal-actions">
            <button type="button" class="btn-session-cancel" onclick="closeSessionModal()">Cancelar</button>
            <button type="button" class="btn-session-confirm" onclick="forceLogin()">Sim, entrar aqui</button>
        </div>
    </div>
</div>

<style>
    .auth-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f9fafb;
    }

    /* ===== LEFT PANEL ===== */
    .auth-left {
        flex: 0 0 50%;
        background: linear-gradient(135deg, #ff9700 0%, #f57c00 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .auth-left-content {
        position: relative;
        z-index: 2;
        padding: 3rem;
        color: #fff;
        max-width: 480px;
    }

    .auth-left-content .auth-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 2.5rem;
    }

    .auth-left-content .auth-brand .brand-logo-full {
        width: 220px;
        max-width: 100%;
        height: auto;
        filter: none;
    }

    .auth-mobile-brand .brand-logo-mobile {
        width: 180px;
        max-width: 100%;
        height: auto;
    }

    .auth-left-content h1 {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 1rem;
    }

    .auth-left-content p {
        font-size: 1rem;
        opacity: 0.85;
        line-height: 1.6;
    }

    .auth-left-shapes .shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.08;
        background: #fff;
    }

    .auth-left-shapes .shape-1 {
        width: 300px;
        height: 300px;
        top: -80px;
        right: -60px;
    }

    .auth-left-shapes .shape-2 {
        width: 200px;
        height: 200px;
        bottom: -50px;
        left: -40px;
    }

    .auth-left-shapes .shape-3 {
        width: 120px;
        height: 120px;
        bottom: 30%;
        right: 10%;
        opacity: 0.05;
    }

    /* ===== RIGHT PANEL ===== */
    .auth-right {
        flex: 0 0 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .auth-form-wrapper {
        width: 100%;
        max-width: 400px;
    }

    .auth-mobile-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1.5rem;
    }

    .auth-mobile-brand img {
        width: 30px;
        height: 30px;
    }

    .auth-mobile-brand span {
        font-size: 1.1rem;
        font-weight: 700;
        color: #f57c00;
    }

    .auth-form-header h2 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.25rem;
    }

    .auth-form-header p {
        font-size: 0.9rem;
        margin-bottom: 2rem;
    }

    .auth-field {
        margin-bottom: 1.25rem;
    }

    .auth-field label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.4rem;
    }

    .auth-input-group {
        position: relative;
    }

    .auth-input-group i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 1.1rem;
    }

    .auth-input-group .form-control {
        padding-left: 42px;
        height: 48px;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        background: #fff;
    }

    .auth-input-group .form-control:focus {
        border-color: #f57c00;
        box-shadow: 0 0 0 3px rgba(245, 124, 0, 0.15);
    }

    .auth-input-group .form-control::placeholder {
        color: #c4c9d0;
    }

    .auth-error {
        background: #fef2f2;
        color: #dc2626;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-auth-submit {
        width: 100%;
        height: 48px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 0.5rem;
    }

    .btn-auth-submit:hover {
        opacity: 0.92;
        transform: translateY(-1px);
    }

    .btn-auth-submit:active {
        transform: translateY(0);
    }

    .btn-auth-submit:disabled {
        opacity: 0.65;
        cursor: not-allowed;
    }

    .auth-footer {
        text-align: center;
        margin-top: 2rem;
    }

    .auth-footer a {
        color: #6b7280;
        font-size: 0.85rem;
        text-decoration: none;
        transition: color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .auth-footer a:hover {
        color: #f57c00;
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 991px) {
        .auth-left {
            display: none;
        }

        .auth-right {
            flex: 0 0 100%;
        }
    }

    @@media (max-width: 575px) {
        .auth-right {
            padding: 1.5rem;
        }

        .auth-form-header h2 {
            font-size: 1.35rem;
        }
    }

    /* ===== SESSION MODAL ===== */
    .session-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .session-modal {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        max-width: 420px;
        width: 90%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    }

    .session-modal-icon {
        font-size: 3rem;
        color: #f59e0b;
        margin-bottom: 1rem;
    }

    .session-modal h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }

    .session-modal p {
        color: #6b7280;
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 0.5rem;
    }

    .session-modal-actions {
        display: flex;
        gap: 12px;
        margin-top: 1.5rem;
        justify-content: center;
    }

    .btn-session-cancel {
        padding: 10px 24px;
        border-radius: 10px;
        border: 2px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: border-color 0.2s;
    }

    .btn-session-cancel:hover {
        border-color: #d1d5db;
        color: #374151;
    }

    .btn-session-confirm {
        padding: 10px 24px;
        border-radius: 10px;
        border: none;
        background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-session-confirm:hover {
        opacity: 0.9;
    }
</style>

@code {
    [Parameter]
    public string Identifier { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private string? ErrorMessage => Error switch
    {
        "invalid" => "Login ou senha inválidos.",
        "empty" => "Preencha o login e a senha.",
        _ => null
    };

    protected override void OnInitialized()
    {
        var user = Auth.GetCurrentUser();
        if (user is not null)
        {
            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
    }
}

<script suppress-error="BL9992">
    var skipSessionCheck = false;

    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('loginForm');
        if (!form) return;

        form.addEventListener('submit', async function (e) {
            if (skipSessionCheck) return; // Let form submit normally

            e.preventDefault();

            var login = document.getElementById('loginField').value;
            var password = document.getElementById('passwordField').value;
            var tenant = '@Identifier';

            if (!login || !password) {
                showLoginError('Preencha o login e a senha.');
                return;
            }

            setLoading(true);
            hideLoginError();

            try {
                var resp = await fetch('/auth/check-session', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tenantIdentifier: tenant, login: login, password: password })
                });

                var data = await resp.json();

                if (!data.valid) {
                    showLoginError('Login ou senha inválidos.');
                    setLoading(false);
                    return;
                }

                if (data.hasActiveSession) {
                    setLoading(false);
                    document.getElementById('sessionModal').style.display = 'flex';
                    return;
                }

                // No active session — submit normally
                skipSessionCheck = true;
                form.submit();
            } catch {
                setLoading(false);
                skipSessionCheck = true;
                form.submit();
            }
        });
    });

    function forceLogin() {
        document.getElementById('sessionModal').style.display = 'none';
        skipSessionCheck = true;
        var form = document.getElementById('loginForm');
        if (form) form.submit();
    }

    function closeSessionModal() {
        document.getElementById('sessionModal').style.display = 'none';
    }

    function showLoginError(msg) {
        var el = document.getElementById('loginError');
        el.innerHTML = '<i class="la la-exclamation-circle"></i> ' + msg;
        el.style.display = 'flex';
    }

    function hideLoginError() {
        document.getElementById('loginError').style.display = 'none';
    }

    function setLoading(loading) {
        var btn = document.getElementById('btnSubmit');
        var text = document.getElementById('btnText');
        var icon = document.getElementById('btnIcon');
        if (loading) {
            btn.disabled = true;
            text.textContent = 'Verificando...';
            icon.className = 'la la-spinner la-spin';
        } else {
            btn.disabled = false;
            text.textContent = 'Entrar';
            icon.className = 'ft-arrow-right';
        }
    }
</script>

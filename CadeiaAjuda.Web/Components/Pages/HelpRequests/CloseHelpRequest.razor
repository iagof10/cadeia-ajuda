@page "/help-requests/close"
@layout AdminLayout
@inject AuthStateService AuthState
@inject HelpRequestApiClient HelpRequestApi
@inject NavigationManager Navigation
@using CadeiaAjuda.Web.Services
@using Microsoft.AspNetCore.SignalR
@inject IHubContext<CadeiaAjuda.Web.Hubs.HelpRequestHub> Hub
@inject PersistentComponentState ApplicationState
@implements IDisposable
@rendermode InteractiveServer

<div class="content-header row">
    <div class="content-header-left col-md-6 col-12 mb-2">
        <h3 class="content-header-title mb-0">Encerrar Chamado</h3>
        <p class="text-muted mt-1 mb-0">Selecione um chamado aberto para encerrar utilizando seu usuário logado.</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="alert alert-@alertType alert-dismissible mb-2" role="alert">
        <button type="button" class="close" @onclick="() => alertMessage = null"><span>&times;</span></button>
        <i class="la la-@(alertType == "success" ? "check-circle" : "warning")"></i> @alertMessage
    </div>
}

@if (loading)
{
    <div class="text-center py-3">
        <i class="la la-spinner la-spin font-large-1"></i> Carregando chamados...
    </div>
}
else if (openRequests.Count == 0)
{
    <div class="card">
        <div class="card-body text-center text-muted py-4">
            <i class="la la-check-circle font-large-2 d-block mb-1" style="color:#4caf50;"></i>
            <strong>Nenhum chamado aberto!</strong><br />
            Todos os chamados foram encerrados.
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-content">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Setor</th>
                                <th>Tipo</th>
                                <th>Recurso</th>
                                <th>Solicitante</th>
                                <th>Status</th>
                                <th>Data</th>
                                <th>Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in openRequests)
                            {
                                <tr>
                                    <td><span style="font-family:'Courier New',monospace;font-weight:700;color:#1e9ff2;">@r.Code</span></td>
                                    <td>
                                        <span style="display:inline-block;width:14px;height:14px;border-radius:50%;background-color:@(r.SectorColor ?? "#999");vertical-align:middle;margin-right:6px;border:2px solid rgba(0,0,0,.1);"></span>
                                        @r.SectorName
                                    </td>
                                    <td>@r.HelpRequestTypeName</td>
                                    <td>@r.AreaName</td>
                                    <td>@r.RequestedByUserName</td>
                                    <td><span class="badge @StatusBadgeClass(r.Status)" style="font-size:.8rem;padding:4px 10px;border-radius:4px;">@r.StatusName</span></td>
                                    <td>@r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" disabled="@closingId.HasValue" @onclick="() => CloseRequest(r.Id)">
                                            @if (closingId == r.Id)
                                            {
                                                <i class="la la-spinner la-spin"></i> <text>Encerrando...</text>
                                            }
                                            else
                                            {
                                                <i class="la la-times-circle"></i> <text>Encerrar</text>
                                            }
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<HelpRequestViewModel> openRequests = new();
    private bool loading = true;
    private Guid? closingId;
    private string? alertMessage;
    private string alertType = "success";
    private LoggedUser? currentUser;
    private PersistingComponentStateSubscription _persistingSubscription;

    protected override async Task OnInitializedAsync()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistUserData);

        if (!ApplicationState.TryTakeFromJson<LoggedUser>("closePageUser", out var restored))
        {
            // SSR prerender phase – HttpContext is available
            currentUser = AuthState.GetCurrentUser();
        }
        else
        {
            // Interactive (SignalR) phase – use persisted data
            currentUser = restored;
        }

        if (currentUser is null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadRequests();
    }

    private Task PersistUserData()
    {
        ApplicationState.PersistAsJson("closePageUser", currentUser);
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _persistingSubscription.Dispose();
    }

    private async Task LoadRequests()
    {
        loading = true;
        if (currentUser is null) return;

        var all = await HelpRequestApi.GetByTenantIdAsync(currentUser.TenantId);
        openRequests = all.Where(r => r.Status <= 2).OrderByDescending(r => r.CreatedAt).ToList();
        loading = false;
    }

    private async Task CloseRequest(Guid id)
    {
        if (currentUser is null) return;

        closingId = id;
        alertMessage = null;

        try
        {
            var response = await HelpRequestApi.CloseAsync(id, new HelpRequestCloseModel { ClosedByUserId = currentUser.Id });
            if (response.IsSuccessStatusCode)
            {
                await Hub.Clients.Group(currentUser.TenantId.ToString()).SendAsync("HelpRequestsChanged");
                alertMessage = "Chamado encerrado com sucesso!";
                alertType = "success";
                await LoadRequests();
            }
            else
            {
                alertMessage = "Erro ao encerrar o chamado.";
                alertType = "danger";
            }
        }
        catch
        {
            alertMessage = "Erro de conexão.";
            alertType = "danger";
        }

        closingId = null;
    }

    private static string StatusBadgeClass(int status) => status switch
    {
        0 => "status-open",
        1 => "status-inprogress",
        2 => "status-escalated",
        3 => "status-resolved",
        4 => "status-closed",
        _ => ""
    };
}

<style>
    .status-open { background: #fff3cd; color: #856404; }
    .status-inprogress { background: #cce5ff; color: #004085; }
    .status-escalated { background: #f8d7da; color: #721c24; }
    .status-resolved { background: #d4edda; color: #155724; }
    .status-closed { background: #e2e3e5; color: #383d41; }
</style>

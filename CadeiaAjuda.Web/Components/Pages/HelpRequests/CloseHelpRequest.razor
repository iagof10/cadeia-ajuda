@page "/help-requests/close"
@layout AdminLayout

<div class="content-header row">
    <div class="content-header-left col-md-6 col-12 mb-2">
        <h3 class="content-header-title mb-0">Encerrar Chamado</h3>
        <p class="text-muted mt-1 mb-0">Selecione um chamado aberto para encerrar utilizando seu usuário logado.</p>
    </div>
</div>

<div id="closeAlertArea"></div>

<div id="loadingArea" class="text-center py-3">
    <i class="la la-spinner la-spin font-large-1"></i> Carregando chamados...
</div>

<div id="emptyArea" class="card" style="display:none;">
    <div class="card-body text-center text-muted py-4">
        <i class="la la-check-circle font-large-2 d-block mb-1" style="color:#4caf50;"></i>
        <strong>Nenhum chamado aberto!</strong><br />
        Todos os chamados foram encerrados.
    </div>
</div>

<div id="tableArea" class="card" style="display:none;">
    <div class="card-content">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Setor</th>
                            <th>Tipo</th>
                            <th>Recurso</th>
                            <th>Solicitante</th>
                            <th>Status</th>
                            <th>Data</th>
                            <th>Ação</th>
                        </tr>
                    </thead>
                    <tbody id="closeListBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="js/close-help-requests.js"></script>

<style>
    .status-open { background: #fff3cd; color: #856404; }
    .status-inprogress { background: #cce5ff; color: #004085; }
    .status-escalated { background: #f8d7da; color: #721c24; }
    .status-resolved { background: #d4edda; color: #155724; }
    .status-closed { background: #e2e3e5; color: #383d41; }
</style>

@page "/help-requests"
@layout AdminLayout

<PageTitle>Cadeia de Ajuda - Chamados</PageTitle>

<style>
    /* Tab nav overrides */
    .wizard-tabs .nav-link { font-weight:600; color:#6b6f82; cursor:default; }
    .wizard-tabs .nav-link.active { color:#1e9ff2; }
    .wizard-tabs .nav-link.done { color:#4caf50; cursor:pointer; }
    .wizard-tabs .nav-link.done:hover { color:#388e3c; }
    .wizard-tabs .nav-link .step-number { display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:50%; background:#e4e7ed; color:#6b6f82; font-weight:700; font-size:.8rem; margin-right:.4rem; transition:all .2s; }
    .wizard-tabs .nav-link.active .step-number { background:linear-gradient(135deg,#1e9ff2 0%,#1565c0 100%); color:#fff; }
    .wizard-tabs .nav-link.done .step-number { background:#4caf50; color:#fff; }

    .tab-pane { display:none; }
    .tab-pane.active { display:block; }

    /* Selection Cards */
    .selection-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:.75rem; }
    .selection-card { border:2px solid #e4e7ed; border-radius:10px; padding:1rem; cursor:pointer; transition:all .2s; background:#fff; text-align:center; position:relative; }
    .selection-card:hover { border-color:#1e9ff2; background:#f0f8ff; }
    .selection-card.selected { border-color:#1e9ff2; background:#e3f2fd; box-shadow:0 0 0 3px rgba(30,159,242,.15); }
    .selection-card .card-icon { font-size:1.8rem; margin-bottom:.5rem; }
    .selection-card .card-name { font-weight:700; font-size:.95rem; color:#404e67; }
    .selection-card .check-mark { display:none; position:absolute; top:8px; right:8px; color:#1e9ff2; font-size:1.2rem; }
    .selection-card.selected .check-mark { display:block; }

    .sector-dot { display:inline-block; width:14px; height:14px; border-radius:50%; margin-right:6px; vertical-align:middle; border:2px solid rgba(0,0,0,.1); }

    /* Type list */
    .type-list-item { display:flex; align-items:center; padding:.75rem 1rem; border:2px solid #e4e7ed; border-radius:8px; cursor:pointer; transition:all .2s; background:#fff; margin-bottom:.5rem; gap:.75rem; }
    .type-list-item:hover { border-color:#1e9ff2; background:#f0f8ff; }
    .type-list-item.selected { border-color:#1e9ff2; background:#e3f2fd; }
    .type-list-item .type-radio { width:20px; height:20px; border:2px solid #ccc; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; transition:all .2s; }
    .type-list-item.selected .type-radio { border-color:#1e9ff2; background:#1e9ff2; }
    .type-list-item.selected .type-radio::after { content:''; width:8px; height:8px; border-radius:50%; background:#fff; }
    .type-list-item .type-info { flex:1; }
    .type-list-item .type-name { font-weight:600; color:#404e67; }
    .type-list-item .type-desc { font-size:.8rem; color:#8d9daa; }

    /* Area leaf cards */
    .area-leaf-card { display:flex; align-items:center; padding:.65rem 1rem; border:2px solid #e4e7ed; border-radius:8px; cursor:pointer; transition:all .2s; background:#fff; margin-bottom:.5rem; gap:.75rem; }
    .area-leaf-card:hover { border-color:#1e9ff2; background:#f0f8ff; }
    .area-leaf-card.selected { border-color:#1e9ff2; background:#e3f2fd; }
    .area-leaf-card .area-radio { width:20px; height:20px; border:2px solid #ccc; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; transition:all .2s; }
    .area-leaf-card.selected .area-radio { border-color:#1e9ff2; background:#1e9ff2; }
    .area-leaf-card.selected .area-radio::after { content:''; width:8px; height:8px; border-radius:50%; background:#fff; }
    .area-leaf-card .area-path { font-size:.75rem; color:#8d9daa; }
    .area-leaf-card .area-name { font-weight:600; color:#404e67; }

    /* Status badges */
    .status-open { background:#fff3cd; color:#856404; }
    .status-inprogress { background:#cce5ff; color:#004085; }
    .status-escalated { background:#f8d7da; color:#721c24; }
    .status-resolved { background:#d4edda; color:#155724; }
    .status-closed { background:#e2e3e5; color:#383d41; }

    .help-request-code { font-family:'Courier New',monospace; font-weight:700; color:#1e9ff2; }

    /* Summary card */
    .summary-section { background:#f8f9fa; border-radius:8px; padding:1rem 1.25rem; margin-bottom:1rem; }
    .summary-label { font-size:.8rem; color:#8d9daa; text-transform:uppercase; letter-spacing:.5px; margin-bottom:.25rem; }
    .summary-value { font-weight:700; color:#404e67; }
</style>

<!-- ========== LIST VIEW ========== -->
<div id="viewList">
    <div class="row mb-2">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="content-header-title mb-0">Cadeia de Ajuda</h4>
            </div>
            <button class="btn btn-warning" id="btnNewRequest" type="button">
                <i class="ft-plus"></i> Novo Chamado
            </button>
        </div>
    </div>

    <div id="alertList"></div>

    <div id="loadingList" class="text-center py-3">
        <i class="la la-spinner la-spin font-large-1"></i> Carregando...
    </div>

    <div id="emptyList" style="display:none;">
        <div class="card">
            <div class="card-body text-center text-muted py-4">
                <i class="la la-life-ring font-large-2 d-block mb-1"></i>
                Nenhum chamado encontrado. Clique em "Novo Chamado" para criar.
            </div>
        </div>
    </div>

    <div class="card" id="listCard" style="display:none;">
        <div class="card-content">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Setor</th>
                                <th>Tipo</th>
                                <th>Recurso</th>
                                <th>Solicitante</th>
                                <th>Status</th>
                                <th>Data</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody id="listBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ========== CREATE WIZARD ========== -->
<div id="viewCreate" style="display:none;">
    <div class="row mb-2">
        <div class="col-12">
            <h4 class="content-header-title mb-0">Novo Chamado</h4>
        </div>
    </div>

    <div id="alertCreate"></div>

    <div class="card">
        <div class="card-body">
            <!-- Steps indicator -->
            <ul class="nav nav-tabs nav-underline no-hover-bg wizard-tabs" id="wizardSteps">
                <li class="nav-item">
                    <a class="nav-link active" data-step="0" href="javascript:void(0)">
                        <span class="step-number">1</span> Setor
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-step="1" href="javascript:void(0)">
                        <span class="step-number">2</span> Tipo de Solicitação
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-step="2" href="javascript:void(0)">
                        <span class="step-number">3</span> Recurso
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-step="3" href="javascript:void(0)">
                        <span class="step-number">4</span> Confirmação
                    </a>
                </li>
            </ul>
            <div class="tab-content px-1 pt-1">

                <!-- Panel 0: Setor -->
                <div class="tab-pane active" id="panel0">
                    <h5 class="mb-3"><i class="la la-sitemap text-primary"></i> Selecione o Setor</h5>
                    <p class="text-muted mb-3">Escolha para qual setor deseja enviar o chamado de ajuda.</p>
                    <div id="sectorGrid" class="selection-grid"></div>
                    <div id="sectorLoading" class="text-center py-3">
                        <i class="la la-spinner la-spin font-large-1"></i> Carregando setores...
                    </div>
                </div>

                <!-- Panel 1: Tipo -->
                <div class="tab-pane" id="panel1">
                    <h5 class="mb-3"><i class="la la-question-circle text-primary"></i> Selecione o Tipo de Solicitação</h5>
                    <p class="text-muted mb-3">Escolha o tipo de ajuda que você precisa.</p>
                    <div id="typeList"></div>
                    <div id="typeEmpty" class="text-center text-muted py-3" style="display:none;">
                        <i class="la la-info-circle"></i> Nenhum tipo de solicitação encontrado para este setor.
                    </div>
                </div>

                <!-- Panel 2: Recurso -->
                <div class="tab-pane" id="panel2">
                    <h5 class="mb-3"><i class="la la-cubes text-primary"></i> Selecione o Recurso</h5>
                    <p class="text-muted mb-3">Escolha em qual recurso (posto/equipamento) você está.</p>
                    <div id="areaList"></div>
                    <div id="areaEmpty" class="text-center text-muted py-3" style="display:none;">
                        <i class="la la-info-circle"></i> Nenhum recurso (nó final) encontrado.
                    </div>
                </div>

                <!-- Panel 3: Confirmação -->
                <div class="tab-pane" id="panel3">
                    <h5 class="mb-3"><i class="la la-check-circle text-primary"></i> Confirme o Chamado</h5>
                    <p class="text-muted mb-3">Revise as informações antes de abrir o chamado.</p>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="summary-section">
                                <div class="summary-label">Setor</div>
                                <div class="summary-value" id="summSector">—</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="summary-section">
                                <div class="summary-label">Tipo de Solicitação</div>
                                <div class="summary-value" id="summType">—</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="summary-section">
                                <div class="summary-label">Recurso</div>
                                <div class="summary-value" id="summArea">—</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /tab-content -->

            <!-- Navigation buttons -->
            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                <button class="btn btn-light" id="btnBackToList" type="button" style="border-radius:6px;">
                    <i class="ft-arrow-left"></i> Voltar
                </button>
                <button class="btn btn-warning" id="btnSubmit" type="button" style="display:none;border-radius:6px;padding:8px 32px;">
                    <i class="la la-check"></i> Abrir Chamado
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Encerrar com Login/Senha -->
<div class="modal fade" id="closeAuthModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="la la-lock"></i> Encerrar Chamado</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div id="closeAuthAlert"></div>
                <p class="text-muted mb-3">Informe suas credenciais para encerrar o chamado <strong id="closeAuthCode"></strong>.</p>
                <div class="form-group">
                    <label for="closeAuthLogin">Usuário</label>
                    <input type="text" class="form-control" id="closeAuthLogin" placeholder="Login" autocomplete="username" />
                </div>
                <div class="form-group">
                    <label for="closeAuthPassword">Senha</label>
                    <input type="password" class="form-control" id="closeAuthPassword" placeholder="Senha" autocomplete="current-password" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="btnConfirmCloseAuth">
                    <i class="la la-check"></i> Encerrar
                </button>
            </div>
        </div>
    </div>
</div>

<script suppress-error="BL9992">
    (function () {
        'use strict';

        // Prevent double-init on Blazor enhanced nav
        if (window.__helpRequestsInitialized) return;
        window.__helpRequestsInitialized = true;

        // ---- State ----
        var currentUser = null;
        var requests = [];
        var sectors = [];
        var helpRequestTypes = [];
        var areas = [];

        // Wizard state
        var currentStep = 0;
        var selectedSectorId = null;
        var selectedTypeId = null;
        var selectedAreaId = null;
        var closingRequestId = null;

        // ---- Helpers ----
        function $(id) { return document.getElementById(id); }

        function escapeHtml(str) {
            var div = document.createElement('div');
            div.textContent = str || '';
            return div.innerHTML;
        }

        function showAlert(containerId, msg, type) {
            $(containerId).innerHTML =
                '<div class="alert alert-' + type + ' alert-dismissible mb-2" role="alert">' +
                '<button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>' +
                '<i class="la la-' + (type === 'success' ? 'check-circle' : 'warning') + '"></i> ' + escapeHtml(msg) +
                '</div>';
        }

        function statusBadge(status) {
            var map = { 0:'status-open', 1:'status-inprogress', 2:'status-escalated', 3:'status-resolved', 4:'status-closed' };
            return map[status] || '';
        }

        function formatDate(isoStr) {
            if (!isoStr) return '\u2014';
            var d = new Date(isoStr);
            return d.toLocaleDateString('pt-BR') + ' ' + d.toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit' });
        }

        // ---- API ----
        async function fetchJson(url) {
            var resp = await fetch(url);
            if (!resp.ok) throw new Error('Erro ao carregar dados');
            return await resp.json();
        }

        async function loadCurrentUser() {
            try { currentUser = await fetchJson('/bff/me'); } catch (e) { currentUser = null; }
        }

        async function loadRequests() {
            $('loadingList').style.display = '';
            $('emptyList').style.display = 'none';
            $('listCard').style.display = 'none';
            try { requests = await fetchJson('/bff/help-requests'); } catch (e) { requests = []; }
            $('loadingList').style.display = 'none';
            renderList();
        }

        async function loadSectors() {
            try { sectors = await fetchJson('/bff/sectors'); } catch (e) { sectors = []; }
        }

        async function loadHelpRequestTypes() {
            try { helpRequestTypes = await fetchJson('/bff/help-request-types'); } catch (e) { helpRequestTypes = []; }
        }

        async function loadAreas() {
            try { areas = await fetchJson('/bff/areas'); } catch (e) { areas = []; }
        }

        // ---- List ----
        function renderList() {
            var body = $('listBody');
            body.innerHTML = '';

            if (requests.length === 0) {
                $('emptyList').style.display = '';
                $('listCard').style.display = 'none';
                return;
            }

            $('emptyList').style.display = 'none';
            $('listCard').style.display = '';

            requests.forEach(function (r) {
                var tr = document.createElement('tr');
                var isClosed = r.status === 4 || r.status === 3;
                var actionHtml = isClosed
                    ? '<span class="text-muted"><i class="la la-check-circle"></i> Encerrado</span>'
                    : '<button type="button" class="btn btn-sm btn-outline-danger btn-close-auth" data-id="' + r.id + '" data-code="' + escapeHtml(r.code) + '"><i class="la la-times-circle"></i> Encerrar</button>';

                tr.innerHTML =
                    '<td><span class="help-request-code">' + escapeHtml(r.code) + '</span></td>' +
                    '<td><span class="sector-dot" style="background-color:' + escapeHtml(r.sectorColor || '#999') + ';"></span>' + escapeHtml(r.sectorName) + '</td>' +
                    '<td>' + escapeHtml(r.helpRequestTypeName) + '</td>' +
                    '<td>' + escapeHtml(r.areaName) + '</td>' +
                    '<td>' + escapeHtml(r.requestedByUserName) + '</td>' +
                    '<td><span class="badge ' + statusBadge(r.status) + '" style="font-size:.8rem;padding:4px 10px;border-radius:4px;">' + escapeHtml(r.statusName) + '</span></td>' +
                    '<td>' + formatDate(r.createdAt) + '</td>' +
                    '<td>' + actionHtml + '</td>';
                body.appendChild(tr);
            });

            body.querySelectorAll('.btn-close-auth').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    closingRequestId = btn.getAttribute('data-id');
                    $('closeAuthCode').textContent = btn.getAttribute('data-code');
                    $('closeAuthLogin').value = '';
                    $('closeAuthPassword').value = '';
                    $('closeAuthAlert').innerHTML = '';
                    jQuery('#closeAuthModal').modal('show');
                });
            });
        }

        // ---- View switching ----
        function showListView() {
            $('viewList').style.display = '';
            $('viewCreate').style.display = 'none';
        }

        function showCreateView() {
            $('viewList').style.display = 'none';
            $('viewCreate').style.display = '';
            resetWizard();
        }

        // ---- Wizard ----
        function resetWizard() {
            currentStep = 0;
            selectedSectorId = null;
            selectedTypeId = null;
            selectedAreaId = null;
            $('alertCreate').innerHTML = '';
            updateWizardUI();
            renderSectors();
        }

        function updateWizardUI() {
            var tabs = $('wizardSteps').querySelectorAll('.nav-link');
            tabs.forEach(function (el, i) {
                el.classList.remove('active', 'done');
                if (i < currentStep) el.classList.add('done');
                if (i === currentStep) el.classList.add('active');
            });

            [$('panel0'), $('panel1'), $('panel2'), $('panel3')].forEach(function (p, i) {
                if (p) p.classList.toggle('active', i === currentStep);
            });

            $('btnSubmit').style.display = currentStep === 3 ? '' : 'none';
        }

        function goToStep(step) {
            $('alertCreate').innerHTML = '';
            currentStep = step;
            updateWizardUI();
        }

        // ---- Step 0: Sectors ----
        function renderSectors() {
            $('sectorLoading').style.display = 'none';
            var grid = $('sectorGrid');
            grid.innerHTML = '';

            var active = sectors.filter(function (s) { return s.active; });

            if (active.length === 0) {
                grid.innerHTML = '<div class="text-center text-muted py-3">Nenhum setor cadastrado.</div>';
                return;
            }

            active.forEach(function (s) {
                var card = document.createElement('div');
                card.className = 'selection-card' + (selectedSectorId === s.id ? ' selected' : '');
                card.innerHTML =
                    '<i class="la la-check check-mark"></i>' +
                    '<div class="card-icon"><span class="sector-dot" style="background-color:' + escapeHtml(s.color || '#999') + ';width:32px;height:32px;display:inline-block;border-radius:50%;border:3px solid rgba(0,0,0,.1);"></span></div>' +
                    '<div class="card-name">' + escapeHtml(s.name) + '</div>';
                card.addEventListener('click', function () {
                    selectedSectorId = s.id;
                    selectedTypeId = null;
                    selectedAreaId = null;
                    renderSectors();
                    renderTypes();
                    goToStep(1);
                });
                grid.appendChild(card);
            });
        }

        // ---- Step 1: Types ----
        function renderTypes() {
            var list = $('typeList');
            list.innerHTML = '';
            $('typeEmpty').style.display = 'none';

            var filtered = helpRequestTypes.filter(function (t) {
                return t.sectorId === selectedSectorId && t.active;
            });

            if (filtered.length === 0) {
                $('typeEmpty').style.display = '';
                return;
            }

            filtered.forEach(function (t) {
                var item = document.createElement('div');
                item.className = 'type-list-item' + (selectedTypeId === t.id ? ' selected' : '');
                item.innerHTML =
                    '<div class="type-radio"></div>' +
                    '<div class="type-info">' +
                        '<div class="type-name">' + escapeHtml(t.name) + '</div>' +
                        (t.description ? '<div class="type-desc">' + escapeHtml(t.description) + '</div>' : '') +
                    '</div>';
                item.addEventListener('click', function () {
                    selectedTypeId = t.id;
                    renderTypes();
                    renderAreas();
                    goToStep(2);
                });
                list.appendChild(item);
            });
        }

        // ---- Step 2: Areas (leaf nodes only) ----
        function getLeafAreas() {
            var parentIds = {};
            areas.forEach(function (a) { if (a.parentId) parentIds[a.parentId] = true; });
            return areas.filter(function (a) { return a.active && !parentIds[a.id]; });
        }

        function getAreaPath(areaId) {
            var parts = [];
            var cur = areas.find(function (a) { return a.id === areaId; });
            while (cur) {
                parts.unshift(cur.name);
                var pid = cur.parentId;
                cur = pid ? areas.find(function (a) { return a.id === pid; }) : null;
            }
            return parts.join(' > ');
        }

        function renderAreas() {
            var list = $('areaList');
            list.innerHTML = '';
            $('areaEmpty').style.display = 'none';

            var leaves = getLeafAreas();

            if (leaves.length === 0) {
                $('areaEmpty').style.display = '';
                return;
            }

            leaves.forEach(function (a) {
                var item = document.createElement('div');
                item.className = 'area-leaf-card' + (selectedAreaId === a.id ? ' selected' : '');
                var path = getAreaPath(a.id);
                var pathParts = path.split(' > ');
                var parentPath = pathParts.length > 1 ? pathParts.slice(0, -1).join(' > ') : '';
                item.innerHTML =
                    '<div class="area-radio"></div>' +
                    '<div>' +
                        (parentPath ? '<div class="area-path">' + escapeHtml(parentPath) + '</div>' : '') +
                        '<div class="area-name">' + escapeHtml(a.name) + '</div>' +
                    '</div>';
                item.addEventListener('click', function () {
                    selectedAreaId = a.id;
                    renderAreas();
                    renderSummary();
                    goToStep(3);
                });
                list.appendChild(item);
            });
        }

        // ---- Step 3: Summary ----
        function renderSummary() {
            var sector = sectors.find(function (s) { return s.id === selectedSectorId; });
            var type = helpRequestTypes.find(function (t) { return t.id === selectedTypeId; });
            var area = areas.find(function (a) { return a.id === selectedAreaId; });

            $('summSector').innerHTML = sector
                ? '<span class="sector-dot" style="background-color:' + escapeHtml(sector.color || '#999') + ';"></span>' + escapeHtml(sector.name)
                : '\u2014';
            $('summType').textContent = type ? type.name : '\u2014';
            $('summArea').textContent = area ? getAreaPath(area.id) : '\u2014';
        }

        // ---- Submit ----
        async function handleSubmit() {
            $('alertCreate').innerHTML = '';

            if (!currentUser) {
                showAlert('alertCreate', 'Usuário não autenticado.', 'danger');
                return;
            }

            var payload = {
                description: '',
                sectorId: selectedSectorId,
                helpRequestTypeId: selectedTypeId,
                areaId: selectedAreaId,
                requestedByUserId: currentUser.id,
                tenantId: currentUser.tenantId
            };

            var btn = $('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<i class="la la-spinner la-spin"></i> Abrindo...';

            try {
                var resp = await fetch('/bff/help-requests', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (resp.ok) {
                    showListView();
                    await loadRequests();
                    showAlert('alertList', 'Chamado aberto com sucesso!', 'success');
                } else {
                    var body = {};
                    try { body = await resp.json(); } catch (e) { }
                    showAlert('alertCreate', body.error || 'Ocorreu um erro ao abrir o chamado.', 'danger');
                }
            } catch (e) {
                showAlert('alertCreate', 'Erro de conexão.', 'danger');
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="la la-check"></i> Abrir Chamado';
        }

        // ---- Close with auth modal ----
        $('btnConfirmCloseAuth').addEventListener('click', async function () {
            var login = $('closeAuthLogin').value.trim();
            var password = $('closeAuthPassword').value;
            var alertEl = $('closeAuthAlert');
            alertEl.innerHTML = '';

            if (!login || !password) {
                alertEl.innerHTML = '<div class="alert alert-warning mb-2"><i class="la la-warning"></i> Informe usuário e senha.</div>';
                return;
            }

            if (!closingRequestId) return;

            var btn = $('btnConfirmCloseAuth');
            btn.disabled = true;
            btn.innerHTML = '<i class="la la-spinner la-spin"></i> Encerrando...';

            try {
                var resp = await fetch('/bff/help-requests/' + closingRequestId + '/close-with-auth', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ login: login, password: password })
                });

                if (resp.ok) {
                    jQuery('#closeAuthModal').modal('hide');
                    await loadRequests();
                    showAlert('alertList', 'Chamado encerrado com sucesso!', 'success');
                } else {
                    var body = {};
                    try { body = await resp.json(); } catch (e) { }
                    alertEl.innerHTML = '<div class="alert alert-danger mb-2"><i class="la la-warning"></i> ' + escapeHtml(body.error || 'Usuário ou senha inválidos.') + '</div>';
                }
            } catch (e) {
                alertEl.innerHTML = '<div class="alert alert-danger mb-2"><i class="la la-warning"></i> Erro de conexão.</div>';
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="la la-check"></i> Encerrar';
        });

        // ---- Events ----
        $('btnNewRequest').addEventListener('click', showCreateView);
        $('btnBackToList').addEventListener('click', showListView);
        $('btnSubmit').addEventListener('click', handleSubmit);

        $('wizardSteps').querySelectorAll('.nav-link').forEach(function (el) {
            el.addEventListener('click', function () {
                var step = parseInt(el.getAttribute('data-step'));
                if (step < currentStep) goToStep(step);
            });
        });

        // ---- Init ----
        (async function init() {
            try {
                await loadCurrentUser();
                await Promise.all([loadRequests(), loadSectors(), loadHelpRequestTypes(), loadAreas()]);
            } catch (e) {
                showAlert('alertList', 'Erro ao carregar dados iniciais. Recarregue a página.', 'danger');
            }
        })();
    })();
</script>

@page "/not-found"
@layout CadeiaAjuda.Web.Components.Layout.AdminLayout

<PageTitle>Página não encontrada - Cadeia Ajuda</PageTitle>

<section>
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-content">
                    <div class="card-body text-center py-5">
                        <i class="ft-alert-circle font-large-5 text-warning d-block mb-2"></i>
                        <h1 class="text-warning" style="font-size:5rem;font-weight:700;margin-bottom:0;">404</h1>
                        <h4 class="mt-1 mb-1">Página não encontrada</h4>
                        <p class="text-muted mb-2">A página que você está procurando não existe ou foi movida.</p>
                        <a href="/dashboard" class="btn btn-warning" data-enhance-nav="false">
                            <i class="ft-home"></i> Voltar ao início
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

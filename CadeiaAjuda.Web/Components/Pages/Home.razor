@page "/"
@layout LoginLayout
@inject NavigationManager Navigation
@inject AuthStateService Auth

<PageTitle>Cadeia Ajuda</PageTitle>

<div class="auth-wrapper">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <img src="app-assets/images/logo/AssistChain-logo-2.png" alt="AssistChain" class="brand-logo-full" />
            </div>
            <h1>Gerencie suas operações com agilidade</h1>
            <p>Plataforma completa para gestão de cadeia de ajuda, chamados e escalonamento em tempo real.</p>
            <div class="auth-left-shapes">
                <div class="shape shape-1"></div>
                <div class="shape shape-2"></div>
                <div class="shape shape-3"></div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-wrapper">
            <div class="auth-form-header">
                <div class="auth-mobile-brand d-lg-none">
                    <img src="app-assets/images/logo/logo.png" alt="logo" />
                    <span>Cadeia Ajuda</span>
                </div>
                <h2>Identifique sua empresa</h2>
                <p class="text-muted">Informe o identificador para acessar o sistema</p>
            </div>

            <form method="post" action="/continue-to-login">
                <div class="auth-field">
                    <label>Identificador da empresa</label>
                    <div class="auth-input-group">
                        <i class="la la-building"></i>
                        <input type="text" name="Identifier" class="form-control" placeholder="ex: minha-empresa" />
                    </div>
                </div>

                <button type="submit" class="btn-auth-submit">
                    <span>Continuar</span>
                    <i class="ft-arrow-right"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    .auth-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f9fafb;
    }

    .auth-left {
        flex: 0 0 50%;
        background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .auth-left-content {
        position: relative;
        z-index: 2;
        padding: 3rem;
        color: #fff;
        max-width: 480px;
    }

    .auth-left-content .auth-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 2.5rem;
    }

    .auth-left-content .auth-brand img {
        width: 36px;
        height: 36px;
        filter: brightness(10);
    }

    .auth-left-content .auth-brand .brand-logo-full {
        width: 220px;
        max-width: 100%;
        height: auto;
        filter: none;
    }

    .auth-left-content h1 {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 1rem;
    }

    .auth-left-content p {
        font-size: 1rem;
        opacity: 0.85;
        line-height: 1.6;
    }

    .auth-left-shapes .shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.08;
        background: #fff;
    }

    .auth-left-shapes .shape-1 {
        width: 300px;
        height: 300px;
        top: -80px;
        right: -60px;
    }

    .auth-left-shapes .shape-2 {
        width: 200px;
        height: 200px;
        bottom: -50px;
        left: -40px;
    }

    .auth-left-shapes .shape-3 {
        width: 120px;
        height: 120px;
        bottom: 30%;
        right: 10%;
        opacity: 0.05;
    }

    .auth-right {
        flex: 0 0 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .auth-form-wrapper {
        width: 100%;
        max-width: 400px;
    }

    .auth-mobile-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1.5rem;
    }

    .auth-mobile-brand img {
        width: 30px;
        height: 30px;
    }

    .auth-mobile-brand span {
        font-size: 1.1rem;
        font-weight: 700;
        color: #f57c00;
    }

    .auth-form-header h2 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.25rem;
    }

    .auth-form-header p {
        font-size: 0.9rem;
        margin-bottom: 2rem;
    }

    .auth-field {
        margin-bottom: 1.25rem;
    }

    .auth-field label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.4rem;
    }

    .auth-input-group {
        position: relative;
    }

    .auth-input-group i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 1.1rem;
    }

    .auth-input-group .form-control {
        padding-left: 42px;
        height: 48px;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        background: #fff;
    }

    .auth-input-group .form-control:focus {
        border-color: #f57c00;
        box-shadow: 0 0 0 3px rgba(245, 124, 0, 0.15);
    }

    .auth-input-group .form-control::placeholder {
        color: #c4c9d0;
    }

    .btn-auth-submit {
        width: 100%;
        height: 48px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: opacity 0.2s, transform 0.15s;
        margin-top: 0.5rem;
    }

    .btn-auth-submit:hover {
        opacity: 0.92;
        transform: translateY(-1px);
    }

    .btn-auth-submit:active {
        transform: translateY(0);
    }

    @@media (max-width: 991px) {
        .auth-left {
            display: none;
        }

        .auth-right {
            flex: 0 0 100%;
        }
    }

    @@media (max-width: 575px) {
        .auth-right {
            padding: 1.5rem;
        }

        .auth-form-header h2 {
            font-size: 1.35rem;
        }
    }
</style>

@code {
    [SupplyParameterFromForm]
    private IdentifierModel model { get; set; } = new();

    protected override void OnInitialized()
    {
        var user = Auth.GetCurrentUser();
        if (user is not null)
        {
            var url = user.UserType == UserType.Andon ? "/andon" : "/home";
            Navigation.NavigateTo(url, forceLoad: true);
        }
    }

    private void GoToLogin()
    {
        if (!string.IsNullOrWhiteSpace(model.Identifier))
        {
            Navigation.NavigateTo($"/login/{model.Identifier.Trim()}", forceLoad: true);
        }
    }

    private sealed class IdentifierModel
    {
        public string Identifier { get; set; } = string.Empty;
    }
}

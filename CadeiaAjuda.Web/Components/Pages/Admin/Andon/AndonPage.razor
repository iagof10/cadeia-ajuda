@page "/andon"
@attribute [LayoutAttribute(typeof(EmptyLayout))]

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Andon - Cadeia de Ajuda</title>
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600,700%7CQuicksand:500,700" rel="stylesheet" />
    <link rel="stylesheet" type="text/css" href="app-assets/vendors/css/vendors.min.css" />
    <link rel="stylesheet" type="text/css" href="app-assets/fonts/simple-line-icons/style.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Open Sans', 'Quicksand', sans-serif;
            background: #1a1d23;
            color: #e8eaed;
            overflow: hidden;
            height: 100vh;
        }

        /* ---- Bottom Clock ---- */
        .andon-clock-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            padding: 6px 0;
            background: rgba(0,0,0,.6);
            backdrop-filter: blur(6px);
        }

        .andon-live-dot {
            display: inline-block;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #4caf50;
            animation: pulse-dot 1.5s ease-in-out infinite;
        }

        .andon-clock {
            font-size: 2.8rem;
            font-weight: 700;
            font-family: 'Courier New', monospace;
            color: #fff;
            letter-spacing: 4px;
        }

        @@keyframes pulse-dot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: .4; transform: scale(.7); }
        }

        /* ---- Indicator ---- */
        .andon-page-indicator {
            position: fixed;
            bottom: 52px;
            left: 0;
            right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 6px 0;
        }

        .andon-page-indicator.hidden { display: none; }

        .andon-page-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #444;
            transition: background .3s, transform .3s;
            flex-shrink: 0;
        }

        .andon-page-dot.active {
            background: #1e9ff2;
            transform: scale(1.4);
        }

        /* ---- Board ---- */
        .andon-board-container {
            height: calc(100vh - 48px);
            overflow: hidden;
            padding: 6px 10px;
        }

        .andon-board {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
            gap: 8px;
            align-content: start;
            height: 100%;
        }

        /* ---- Card ---- */
        .andon-card {
            background: #2a2e38;
            border-radius: 12px;
            overflow: hidden;
            border: none;
            box-shadow: 0 4px 16px rgba(0,0,0,.3);
        }

        .andon-card.andon-status-escalated {
            animation: flash-escalated 1.8s ease-in-out infinite;
        }

        @@keyframes flash-escalated {
            0%, 100% { box-shadow: 0 4px 16px rgba(0,0,0,.3); }
            50% { box-shadow: 0 0 30px 8px rgba(244,67,54,.35); }
        }

        .andon-card.urgency-warning { outline: 3px solid rgba(255,152,0,.5); }
        .andon-card.urgency-critical { outline: 3px solid rgba(244,67,54,.6); animation: flash-critical 1.5s ease-in-out infinite; }

        @@keyframes flash-critical {
            0%, 100% { outline-color: rgba(244,67,54,.6); }
            50% { outline-color: rgba(244,67,54,.15); }
        }

        /* Header */
        .andon-card-header {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: .7rem 1rem;
        }

        .andon-code {
            font-family: 'Quicksand', 'Courier New', monospace;
            font-size: 2.6rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: 3px;
            text-shadow: 0 2px 4px rgba(0,0,0,.35);
        }

        /* Body */
        .andon-card-body { padding: .5rem 1rem; }

        .andon-sector-name {
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: .3rem;
            text-align: center;
        }

        .andon-info-row { display: flex; gap: 2rem; justify-content: center; }
        .andon-info-item { text-align: center; }

        .andon-info-label {
            display: block;
            font-size: 1.15rem;
            color: #6b7a8d;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 2px;
            font-weight: 600;
        }

        .andon-info-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: #e0e0e0;
        }

        /* Footer */
        .andon-card-footer {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: .5rem 1rem;
            border-top: 1px solid rgba(255,255,255,.08);
        }

        .andon-time {
            font-weight: 700;
            font-size: 2.4rem;
            color: #b0bec5;
            font-family: 'Courier New', monospace;
            letter-spacing: 3px;
        }

        .andon-time i { margin-right: 10px; font-size: 2.6rem; }

        .urgency-warning .andon-time { color: #ff9800; }
        .urgency-critical .andon-time { color: #f44336; }

        /* ---- Empty State ---- */
        .andon-empty {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: calc(100vh - 48px);
            color: #4a5568;
        }

        .andon-empty i { font-size: 8rem; margin-bottom: 1rem; color: #2d9c4e; }
        .andon-empty h2 { font-size: 3rem; font-weight: 700; color: #4caf50; margin-bottom: .5rem; }
        .andon-empty p { font-size: 1.6rem; color: #6b7a8d; }

        /* ---- Large screens ---- */
        @@media (min-width: 1920px) {
            .andon-board { grid-template-columns: repeat(auto-fill, minmax(480px, 1fr)); }
            .andon-code { font-size: 3rem; }
            .andon-sector-name { font-size: 2.4rem; }
            .andon-info-label { font-size: 1.3rem; }
            .andon-info-value { font-size: 1.8rem; }
            .andon-time { font-size: 2.8rem; }
            .andon-time i { font-size: 3rem; }
            .andon-clock { font-size: 3.2rem; }
        }

        @@media (min-width: 3000px) {
            .andon-board { grid-template-columns: repeat(auto-fill, minmax(600px, 1fr)); gap: 12px; }
            .andon-code { font-size: 4rem; }
            .andon-sector-name { font-size: 3rem; }
            .andon-info-label { font-size: 1.6rem; }
            .andon-info-value { font-size: 2.2rem; }
            .andon-time { font-size: 3.5rem; }
            .andon-time i { font-size: 3.8rem; }
            .andon-clock { font-size: 4rem; }
        }
    </style>
</head>
<body>

    <a href="/home" style="position:fixed;top:12px;left:12px;z-index:9999;width:40px;height:40px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(255,255,255,.1);color:rgba(255,255,255,.5);font-size:20px;text-decoration:none;cursor:pointer;" onclick="window.location.href='/home';return false;">
        &#x2302;
    </a>

    <div class="andon-board-container">
        <div class="andon-board" id="andonBoard"></div>
        <div class="andon-empty" id="emptyState" style="display:none;">
            <i class="la la-check-circle"></i>
            <h2>Tudo em ordem!</h2>
            <p>Nenhum chamado de ajuda em aberto no momento.</p>
        </div>
    </div>

    <div class="andon-page-indicator hidden" id="pageIndicator"></div>

    <div class="andon-clock-bar">
        <span class="andon-live-dot"></span>
        <span class="andon-clock" id="andonClock">--:--:--</span>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="js/andon.js"></script>
</body>
</html>

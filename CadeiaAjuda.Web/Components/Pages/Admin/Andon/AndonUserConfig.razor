@page "/andon/settings"
@using System.ComponentModel.DataAnnotations
@inject AndonUserSettingsApiClient Api
@inject AuthStateService Auth

<PageTitle>Configuração do Andon - Cadeia Ajuda</PageTitle>

<section>
    <div class="row mb-2">
        <div class="col-12">
            <h4 class="content-header-title mb-0">Minha Configuração do Andon</h4>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-content">
                    <div class="card-body">
                        @if (isLoading)
                        {
                            <div class="text-center py-3">
                                <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                            </div>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(successMessage))
                            {
                                <div class="alert alert-success alert-dismissible mb-2" role="alert">
                                    <button type="button" class="close" @onclick="() => successMessage = null"><span>&times;</span></button>
                                    <i class="la la-check-circle"></i> @successMessage
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger alert-dismissible mb-2" role="alert">
                                    <button type="button" class="close" @onclick="() => errorMessage = null"><span>&times;</span></button>
                                    <i class="la la-warning"></i> @errorMessage
                                </div>
                            }

                            <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="andonUserConfigForm">
                                <DataAnnotationsValidator />

                                <p class="text-muted mb-2">
                                    Personalize o comportamento do painel Andon para o seu usuário.
                                </p>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label><i class="ft-clock"></i> Intervalo do Carrossel (segundos) <span class="text-danger">*</span></label>
                                            <InputNumber @bind-Value="model.CarouselIntervalSeconds" class="form-control" />
                                            <small class="text-muted">Tempo entre a troca automática dos cards.</small>
                                            <ValidationMessage For="() => model.CarouselIntervalSeconds" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="d-block"><i class="ft-eye"></i> Exibir Relógio</label>
                                            <div class="custom-control custom-switch">
                                                <InputCheckbox @bind-Value="model.ShowClock" class="custom-control-input" id="showClockSwitch" />
                                                <label class="custom-control-label" for="showClockSwitch">
                                                    @(model.ShowClock ? "Sim" : "Não")
                                                </label>
                                            </div>
                                            <small class="text-muted">Mostra ou oculta o relógio na barra inferior.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="d-block"><i class="ft-volume-2"></i> Alerta Sonoro</label>
                                            <div class="custom-control custom-switch">
                                                <InputCheckbox @bind-Value="model.EnableSound" class="custom-control-input" id="enableSoundSwitch" />
                                                <label class="custom-control-label" for="enableSoundSwitch">
                                                    @(model.EnableSound ? "Sim" : "Não")
                                                </label>
                                            </div>
                                            <small class="text-muted">Emite som ao receber novo chamado.</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-actions text-right mt-2">
                                    <button type="submit" class="btn btn-warning" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <i class="la la-spinner la-spin"></i>
                                        }
                                        <i class="la la-check"></i> Salvar Configuração
                                    </button>
                                </div>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromForm]
    private AndonUserFormModel model { get; set; } = new();

    private bool isLoading = true;
    private bool isSaving;
    private bool _loaded;
    private string? errorMessage;
    private string? successMessage;
    private Guid userId;

    protected override async Task OnInitializedAsync()
    {
        var user = Auth.GetCurrentUser();
        if (user is null) return;

        userId = user.Id;

        if (!_loaded)
        {
            var data = await Api.GetByUserIdAsync(userId);
            if (data is not null)
            {
                model = new AndonUserFormModel
                {
                    CarouselIntervalSeconds = data.CarouselIntervalSeconds,
                    ShowClock = data.ShowClock,
                    EnableSound = data.EnableSound
                };
            }
            _loaded = true;
        }

        isLoading = false;
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        var response = await Api.UpdateAsync(userId, new AndonUserSettingsFormModel
        {
            CarouselIntervalSeconds = model.CarouselIntervalSeconds,
            ShowClock = model.ShowClock,
            EnableSound = model.EnableSound
        });

        if (response.IsSuccessStatusCode)
        {
            successMessage = "Configuração salva com sucesso.";
        }
        else
        {
            try
            {
                var body = await response.Content.ReadAsStringAsync();
                var error = System.Text.Json.JsonSerializer.Deserialize<ErrorResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                errorMessage = error?.Error ?? "Ocorreu um erro ao salvar.";
            }
            catch
            {
                errorMessage = "Ocorreu um erro ao salvar.";
            }
        }

        isSaving = false;
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
    }

    private class AndonUserFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Informe o intervalo do carrossel.")]
        [System.ComponentModel.DataAnnotations.Range(1, 120, ErrorMessage = "O valor deve ser entre 1 e 120 segundos.")]
        public int CarouselIntervalSeconds { get; set; } = 5;

        public bool ShowClock { get; set; } = true;
        public bool EnableSound { get; set; }
    }
}

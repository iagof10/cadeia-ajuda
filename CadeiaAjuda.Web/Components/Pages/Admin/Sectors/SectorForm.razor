@page "/register/sectors/new"
@page "/register/sectors/edit/{Id:guid}"
@inject SectorApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Navigation

<PageTitle>@(isEdit ? "Editar Setor" : "Novo Setor") - AssistChain</PageTitle>

<section>
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">@(isEdit ? "Editar Setor" : "Novo Setor")</h4>
                </div>
                <div class="card-content">
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible mb-2" role="alert">
                                <button type="button" class="close" @onclick="() => errorMessage = null"><span>&times;</span></button>
                                <i class="la la-warning"></i> @errorMessage
                            </div>
                        }

                        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="sectorForm">
                            <DataAnnotationsValidator />

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Nome <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Name" class="form-control" placeholder="Nome do setor" />
                                        <ValidationMessage For="() => model.Name" />
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <label>Cor <span class="text-danger">*</span></label>
                                        <div class="d-flex align-items-center">
                                            <InputText @bind-Value="model.Color" type="color" class="sector-color-picker" title="Selecione uma cor" />
                                            <span class="ml-1 text-muted" style="font-size: 0.85rem;">@model.Color</span>
                                        </div>
                                        <ValidationMessage For="() => model.Color" />
                                    </div>
                                </div>
                                @if (isEdit)
                                {
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label>Status</label>
                                            <InputSelect @bind-Value="model.ActiveValue" class="form-control">
                                                <option value="true">Ativo</option>
                                                <option value="false">Inativo</option>
                                            </InputSelect>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="form-actions text-right mt-2">
                                <NavLink href="/register/sectors" class="btn btn-secondary mr-1">
                                    <i class="ft-x"></i> Cancelar
                                </NavLink>
                                <button type="submit" class="btn btn-warning" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <i class="la la-spinner la-spin"></i>
                                    }
                                    <i class="la la-check"></i> @(isEdit ? "Salvar Alterações" : "Cadastrar")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .sector-color-picker {
        width: 42px;
        height: 38px;
        padding: 2px;
        border: 2px solid #e4e7ed;
        border-radius: 6px;
        cursor: pointer;
        background: #fff;
    }

    .sector-color-picker::-webkit-color-swatch-wrapper {
        padding: 2px;
    }

    .sector-color-picker::-webkit-color-swatch {
        border: none;
        border-radius: 3px;
    }
</style>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    [SupplyParameterFromForm]
    private SectorFormModel model { get; set; } = new();
    private bool isEdit => Id.HasValue;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var currentUser = Auth.GetCurrentUser();
        if (currentUser is not null)
        {
            var canManage = currentUser.UserType == UserType.Administrator || currentUser.Permissions.Contains("sectors.manage");
            if (!canManage)
            {
                Navigation.NavigateTo("/register/sectors");
                return;
            }
        }

        if (isEdit && string.IsNullOrEmpty(model.Name))
        {
            var sector = await Api.GetByIdAsync(Id!.Value);
            if (sector is not null)
            {
                model = new SectorFormModel
                {
                    Name = sector.Name,
                    Color = sector.Color,
                    SelectedTenantId = sector.TenantId.ToString(),
                    ActiveValue = sector.Active.ToString().ToLower()
                };
            }
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;

        var currentUser = Auth.GetCurrentUser();
        if (currentUser is null)
        {
            errorMessage = "Usu\u00e1rio n\u00e3o autenticado.";
            isSaving = false;
            return;
        }

        if (currentUser.UserType != UserType.Administrator && !currentUser.Permissions.Contains("sectors.manage"))
        {
            errorMessage = "Sem permiss\u00e3o para gerenciar setores.";
            isSaving = false;
            return;
        }

        model.TenantId = currentUser.TenantId;
        model.SelectedTenantId = currentUser.TenantId.ToString();
        model.Active = bool.TryParse(model.ActiveValue, out var active) ? active : true;

        HttpResponseMessage response;

        if (isEdit)
        {
            response = await Api.UpdateAsync(Id!.Value, model);
        }
        else
        {
            response = await Api.CreateAsync(model);
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/register/sectors");
        }
        else
        {
            try
            {
                var body = await response.Content.ReadAsStringAsync();
                var error = System.Text.Json.JsonSerializer.Deserialize<ErrorResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                errorMessage = error?.Error ?? "Ocorreu um erro ao salvar.";
            }
            catch
            {
                errorMessage = "Ocorreu um erro ao salvar.";
            }
        }

        isSaving = false;
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
    }
}

@page "/register/sectors"
@inject SectorApiClient Api
@inject AuthStateService Auth

<PageTitle>Setores - Cadeia Ajuda</PageTitle>

<section class="sectors-list-wrapper">
    <div class="row mb-2">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h4 class="content-header-title mb-0">Setores</h4>
            <NavLink href="/register/sectors/new" class="btn btn-warning" title="Adicionar setor">
                <i class="ft-plus"></i> Novo Setor
            </NavLink>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-2" role="alert">
            <button type="button" class="close" @onclick="() => successMessage = null"><span>&times;</span></button>
            <i class="la la-check-circle"></i> @successMessage
        </div>
    }

    <div class="sectors-list-table">
        <div class="card">
            <div class="card-content">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                     <th>Cor</th>
                                     <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (isLoading)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-3">
                                            <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                                        </td>
                                    </tr>
                                }
                                else if (!sectors.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-3 text-muted">Nenhum setor encontrado.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var sector in sectors)
                                    {
                                        <tr>
                                            <td>@sector.Name</td>
                                            <td>
                                                <span class="sector-color-badge" style="background-color: @sector.Color;" title="@sector.Color"></span>
                                             </td>
                                             <td>
                                                 @if (sector.Active)
                                                {
                                                    <span class="badge badge-success">Ativo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Inativo</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="dropdown">
                                                    <button type="button" class="btn btn-sm btn-link p-0 text-secondary sector-actions-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Mais ações">
                                                        <i class="ft-more-vertical"></i>
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right">
                                                        <NavLink href="@($"/register/sectors/edit/{sector.Id}")" class="dropdown-item">
                                                            <i class="ft-edit-2 mr-1"></i> Editar
                                                        </NavLink>
                                                        <button type="button" class="dropdown-item @(sector.Active ? "text-warning" : "text-success")"
                                                                @onclick="() => ToggleActive(sector)">
                                                            <i class="ft-power mr-1"></i> @(sector.Active ? "Inativar" : "Ativar")
                                                        </button>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .sectors-list-table .table-responsive {
        overflow: visible;
    }

    .sector-color-badge {
        display: inline-block;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        border: 2px solid rgba(0, 0, 0, 0.1);
        vertical-align: middle;
    }

    .sector-actions-toggle {
        box-shadow: none !important;
        background: transparent !important;
        border: 0 !important;
        text-decoration: none !important;
    }

    .sector-actions-toggle:hover,
    .sector-actions-toggle:focus,
    .sector-actions-toggle:active {
        color: #404e67 !important;
        box-shadow: none !important;
        background: transparent !important;
        text-decoration: none !important;
    }

    .sector-actions-toggle i {
        font-size: 1.1rem;
    }
</style>

@code {
    private List<SectorViewModel> sectors = [];
    private bool isLoading = true;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var currentUser = Auth.GetCurrentUser();
        if (currentUser is not null)
            sectors = await Api.GetByTenantIdAsync(currentUser.TenantId);
        isLoading = false;
    }

    private async Task ToggleActive(SectorViewModel sector)
    {
        var response = await Api.ToggleActiveAsync(sector.Id);
        if (response.IsSuccessStatusCode)
        {
            sector.Active = !sector.Active;
            successMessage = $"Setor \"{sector.Name}\" {(sector.Active ? "ativado" : "inativado")} com sucesso.";
        }
    }
}

@page "/tenants/new"
@page "/tenants/edit/{Id:guid}"
@inject TenantApiClient Api
@inject NavigationManager Navigation

<PageTitle>@(isEdit ? "Editar Empresa" : "Nova Empresa") - Cadeia Ajuda</PageTitle>

<section>
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">@(isEdit ? "Editar Empresa" : "Nova Empresa")</h4>
                </div>
                <div class="card-content">
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible mb-2" role="alert">
                                <button type="button" class="close" @onclick="() => errorMessage = null"><span>&times;</span></button>
                                <i class="la la-warning"></i> @errorMessage
                            </div>
                        }

                        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="tenantForm">
                            <DataAnnotationsValidator />

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Nome da Empresa <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Name" class="form-control" placeholder="Razão social" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Nome Fantasia</label>
                                        <InputText @bind-Value="model.TradeName" class="form-control" placeholder="Nome fantasia" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>CNPJ <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Cnpj" class="form-control" placeholder="00.000.000/0000-00" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>E-mail <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Email" class="form-control" placeholder="contato@empresa.com" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Telefone</label>
                                        <InputText @bind-Value="model.Phone" class="form-control" placeholder="(00) 00000-0000" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Identificador do Tenant <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Identifier" class="form-control" placeholder="empresa-xyz" />
                                        <small class="text-muted">Identificador único, sem espaços.</small>
                                    </div>
                                </div>
                                @if (isEdit)
                                {
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Status</label>
                                            <InputSelect @bind-Value="model.ActiveValue" class="form-control">
                                                <option value="true">Ativo</option>
                                                <option value="false">Inativo</option>
                                            </InputSelect>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="row">
                                <div class="col-12">
                                    <h5 class="mt-1">Limites de usuários por tipo</h5>
                                    <p class="text-muted mb-1">Deixe em branco para ilimitado.</p>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Padrão</label>
                                        <InputNumber @bind-Value="model.StandardUserLimit" class="form-control" placeholder="Ilimitado" />
                                        <ValidationMessage For="() => model.StandardUserLimit" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Andon</label>
                                        <InputNumber @bind-Value="model.AndonUserLimit" class="form-control" placeholder="Ilimitado" />
                                        <ValidationMessage For="() => model.AndonUserLimit" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Manager</label>
                                        <InputNumber @bind-Value="model.ManagerUserLimit" class="form-control" placeholder="Ilimitado" />
                                        <ValidationMessage For="() => model.ManagerUserLimit" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>Administrator</label>
                                        <InputNumber @bind-Value="model.AdministratorUserLimit" class="form-control" placeholder="Ilimitado" />
                                        <ValidationMessage For="() => model.AdministratorUserLimit" />
                                    </div>
                                </div>
                            </div>

                            <div class="form-actions text-right mt-2">
                                <NavLink href="/tenants" class="btn btn-secondary mr-1">
                                    <i class="ft-x"></i> Cancelar
                                </NavLink>
                                <button type="submit" class="btn btn-warning" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <i class="la la-spinner la-spin"></i>
                                    }
                                    <i class="la la-check"></i> @(isEdit ? "Salvar Alterações" : "Cadastrar")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    [SupplyParameterFromForm]
    private TenantFormModel model { get; set; } = new();
    private bool isEdit => Id.HasValue;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (isEdit && string.IsNullOrEmpty(model.Name))
        {
            var tenant = await Api.GetByIdAsync(Id!.Value);
            if (tenant is not null)
            {
                model = new TenantFormModel
                {
                    Name = tenant.Name,
                    TradeName = tenant.TradeName,
                    Cnpj = tenant.Cnpj,
                    Email = tenant.Email,
                    Phone = tenant.Phone,
                    Identifier = tenant.Identifier,
                    ActiveValue = tenant.Active.ToString().ToLower(),
                    Active = tenant.Active,
                    StandardUserLimit = tenant.StandardUserLimit,
                    AndonUserLimit = tenant.AndonUserLimit,
                    ManagerUserLimit = tenant.ManagerUserLimit,
                    AdministratorUserLimit = tenant.AdministratorUserLimit
                };
            }
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;

        model.Active = bool.TryParse(model.ActiveValue, out var active) ? active : true;

        HttpResponseMessage response;

        if (isEdit)
        {
            response = await Api.UpdateAsync(Id!.Value, model);
        }
        else
        {
            response = await Api.CreateAsync(model);
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/tenants");
        }
        else
        {
            try
            {
                var body = await response.Content.ReadAsStringAsync();
                var error = System.Text.Json.JsonSerializer.Deserialize<ErrorResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                errorMessage = error?.Error ?? "Ocorreu um erro ao salvar.";
            }
            catch
            {
                errorMessage = "Ocorreu um erro ao salvar.";
            }
        }

        isSaving = false;
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
    }
}

@page "/register/help-request-types"
@inject HelpRequestTypeApiClient Api
@inject AuthStateService Auth

<PageTitle>Tipos de Solicitação - AssistChain</PageTitle>

<section class="hrt-list-wrapper">
    <div class="row mb-2">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h4 class="content-header-title mb-0">Tipos de Solicitação</h4>
            @if (canManage)
            {
                <NavLink href="/register/help-request-types/new" class="btn btn-warning" title="Adicionar tipo de solicitação">
                    <i class="ft-plus"></i> Novo Tipo
                </NavLink>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-2" role="alert">
            <button type="button" class="close" @onclick="() => successMessage = null"><span>&times;</span></button>
            <i class="la la-check-circle"></i> @successMessage
        </div>
    }

    <div class="hrt-list-table">
        <div class="card">
            <div class="card-content">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                    <th>Descrição</th>
                                     <th>Setor</th>
                                     <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (isLoading)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-3">
                                            <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                                        </td>
                                    </tr>
                                }
                                else if (!items.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-3 text-muted">Nenhum tipo de solicitação encontrado.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in items)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>@item.Description</td>
                                             <td><span class="badge" style="background-color:@item.SectorColor;color:#fff">@item.SectorName</span></td>
                                             <td>
                                                @if (item.Active)
                                                {
                                                    <span class="badge badge-success">Ativo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Inativo</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (canManage)
                                                {
                                                <div class="dropdown">
                                                    <button type="button" class="btn btn-sm btn-link p-0 text-secondary hrt-actions-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Mais ações">
                                                        <i class="ft-more-vertical"></i>
                                                    </button>
                                                    <div class="dropdown-menu dropdown-menu-right">
                                                        <NavLink href="@($"/register/help-request-types/edit/{item.Id}")" class="dropdown-item">
                                                            <i class="ft-edit-2 mr-1"></i> Editar
                                                        </NavLink>
                                                        <button type="button" class="dropdown-item @(item.Active ? "text-warning" : "text-success")"
                                                                @onclick="() => ToggleActive(item)">
                                                            <i class="ft-power mr-1"></i> @(item.Active ? "Inativar" : "Ativar")
                                                        </button>
                                                    </div>
                                                </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hrt-list-table .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .hrt-list-table .dropdown-menu {
        position: absolute;
        z-index: 1050;
    }

    .hrt-actions-toggle {
        box-shadow: none !important;
        background: transparent !important;
        border: 0 !important;
        text-decoration: none !important;
    }

    .hrt-actions-toggle:hover,
    .hrt-actions-toggle:focus,
    .hrt-actions-toggle:active {
        color: #404e67 !important;
        box-shadow: none !important;
        background: transparent !important;
        text-decoration: none !important;
    }

    .hrt-actions-toggle i {
        font-size: 1.1rem;
    }
</style>

@code {
    private List<HelpRequestTypeViewModel> items = [];
    private bool isLoading = true;
    private string? successMessage;
    private bool canManage;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var currentUser = Auth.GetCurrentUser();
        if (currentUser is not null)
        {
            canManage = currentUser.UserType == UserType.Administrator || currentUser.Permissions.Contains("help_request_types.manage");
            items = await Api.GetByTenantIdAsync(currentUser.TenantId);
        }
        isLoading = false;
    }

    private async Task ToggleActive(HelpRequestTypeViewModel item)
    {
        var response = await Api.ToggleActiveAsync(item.Id);
        if (response.IsSuccessStatusCode)
        {
            item.Active = !item.Active;
            successMessage = $"Tipo de solicitação \"{item.Name}\" {(item.Active ? "ativado" : "inativado")} com sucesso.";
        }
    }
}

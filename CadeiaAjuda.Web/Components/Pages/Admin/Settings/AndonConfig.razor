@page "/settings/andon"
@page "/andon/settings"

<PageTitle>Configuração do Andon - Cadeia Ajuda</PageTitle>

<style>
    .sector-list { display: flex; flex-wrap: wrap; gap: 10px; padding: 10px; border: 1px solid #e5e7eb; border-radius: 8px; background: #fafafa; margin-bottom: 5px; }
    .sector-chip { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; background: #fff; border: 2px solid #e5e7eb; border-radius: 6px; cursor: pointer; font-size: .9rem; transition: all .15s; user-select: none; }
    .sector-chip:hover { border-color: #f57c00; background: #fff8f0; }
    .sector-chip.selected { border-color: #f57c00; background: #fff3e0; }
    .sector-chip input[type="checkbox"] { accent-color: #f57c00; }
    .sector-dot { display: inline-block; width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
</style>

<section>
    <div class="row mb-2">
        <div class="col-12">
            <h4 class="content-header-title mb-0">Configuração do Andon</h4>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-content">
                    <div class="card-body">

                        <div id="loadingState" class="text-center py-3">
                            <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                        </div>

                        <div id="mainContent" style="display:none;">
                            <div id="alertSuccess" class="alert alert-success alert-dismissible mb-2" role="alert" style="display:none;">
                                <button type="button" class="close" onclick="document.getElementById('alertSuccess').style.display='none'"><span>&times;</span></button>
                                <i class="la la-check-circle"></i> <span id="alertSuccessText"></span>
                            </div>

                            <div id="alertError" class="alert alert-danger alert-dismissible mb-2" role="alert" style="display:none;">
                                <button type="button" class="close" onclick="document.getElementById('alertError').style.display='none'"><span>&times;</span></button>
                                <i class="la la-warning"></i> <span id="alertErrorText"></span>
                            </div>

                            <!-- Admin: seletor de usuário -->
                            <div id="adminSection" style="display:none;">
                                <p class="text-muted mb-2">
                                    Selecione um usuário do tipo Andon para configurar o painel dele.
                                </p>

                                <div id="noUsersAlert" class="alert alert-warning mb-2" style="display:none;">
                                    <i class="la la-info-circle"></i> Nenhum usuário do tipo Andon ativo encontrado.
                                </div>

                                <div id="userSelectRow" class="row mb-2" style="display:none;">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="ft-user"></i> Usuário Andon <span class="text-danger">*</span></label>
                                            <select class="form-control" id="userSelect">
                                                <option value="">-- Selecione --</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Andon user: descrição -->
                            <div id="andonUserSection" style="display:none;">
                                <p class="text-muted mb-2">
                                    Personalize o comportamento do painel Andon.
                                </p>
                            </div>

                            <div id="settingsLoading" class="text-center py-3" style="display:none;">
                                <i class="la la-spinner la-spin font-large-1"></i> Carregando configuração...
                            </div>

                            <div id="settingsForm" style="display:none;">
                                <h6 class="text-muted text-uppercase mt-2 mb-1"><i class="la la-map-marker"></i> Posição na Planta</h6>
                                <hr class="mt-0" />
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="form-group">
                                            <div class="custom-control custom-switch mb-2">
                                                <input type="checkbox" class="custom-control-input" id="ignoreArea" />
                                                <label class="custom-control-label" for="ignoreArea" id="ignoreAreaLabel">Não</label>
                                            </div>
                                            <small class="text-muted d-block mb-2">Quando ativado, o Andon exibirá chamados de todas as plantas/posições.</small>
                                            <div id="areaSelectorsContainer"></div>
                                            <small class="text-muted" id="areaHint">Ao selecionar um nível, o Andon exibirá chamados desse nível e de todos os subníveis abaixo.</small>
                                        </div>
                                    </div>
                                </div>

                                <h6 class="text-muted text-uppercase mt-2 mb-1"><i class="la la-bell"></i> Alertas de Urgência</h6>
                                <hr class="mt-0" />

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="la la-exclamation-triangle text-warning"></i> Alerta Amarelo (minutos) <span class="text-danger">*</span></label>
                                            <input type="number" class="form-control" id="warningMinutes" min="1" max="1440" />
                                            <small class="text-muted">Tempo para o card ficar com borda amarela/laranja.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="la la-exclamation-circle text-danger"></i> Alerta Vermelho (minutos) <span class="text-danger">*</span></label>
                                            <input type="number" class="form-control" id="criticalMinutes" min="1" max="1440" />
                                            <small class="text-muted">Tempo para o card ficar vermelho piscante.</small>
                                        </div>
                                    </div>
                                </div>

                                <h6 class="text-muted text-uppercase mt-2 mb-1"><i class="ft-monitor"></i> Exibição</h6>
                                <hr class="mt-0" />

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label><i class="ft-clock"></i> Intervalo do Carrossel (segundos) <span class="text-danger">*</span></label>
                                            <input type="number" class="form-control" id="carouselInterval" min="1" max="120" />
                                            <small class="text-muted">Tempo entre a troca automática dos cards.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="d-block"><i class="ft-eye"></i> Exibir Relógio</label>
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="showClock" />
                                                <label class="custom-control-label" for="showClock" id="showClockLabel">Sim</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="d-block"><i class="ft-volume-2"></i> Alerta Sonoro</label>
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="enableSound" />
                                                <label class="custom-control-label" for="enableSound" id="enableSoundLabel">Não</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <h6 class="text-muted text-uppercase mt-2 mb-1"><i class="la la-sitemap"></i> Setores Vinculados</h6>
                                <hr class="mt-0" />
                                <div class="mb-1">
                                    <button type="button" class="btn btn-sm btn-outline-primary mr-1" id="btnSelectAllSectors">
                                        <i class="ft-check-square"></i> Marcar Todos
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnDeselectAllSectors">
                                        <i class="ft-square"></i> Desmarcar Todos
                                    </button>
                                </div>
                                <div class="sector-list" id="sectorList">
                                    <small class="text-muted">Carregando setores...</small>
                                </div>
                                <small class="text-muted">Selecione os setores que este usuário pode acessar no Andon.</small>

                                <div class="form-actions text-right mt-2">
                                    <button type="button" class="btn btn-warning" id="saveBtn">
                                        <i class="la la-check"></i> Salvar Configuração
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function () {
        var isAdmin = false;
        var currentUserId = '';
        var selectedUserId = '';
        var allSectors = [];
        var selectedSectorIds = {};
        var currentUserData = null;
        var allAreas = [];
        var selectedAreaId = null;

        var userSelect = document.getElementById('userSelect');
        var showClockEl = document.getElementById('showClock');
        var enableSoundEl = document.getElementById('enableSound');
        var ignoreAreaEl = document.getElementById('ignoreArea');
        var saveBtn = document.getElementById('saveBtn');

        showClockEl.addEventListener('change', function () {
            document.getElementById('showClockLabel').textContent = showClockEl.checked ? 'Sim' : 'Não';
        });
        enableSoundEl.addEventListener('change', function () {
            document.getElementById('enableSoundLabel').textContent = enableSoundEl.checked ? 'Sim' : 'Não';
        });
        ignoreAreaEl.addEventListener('change', function () {
            document.getElementById('ignoreAreaLabel').textContent = ignoreAreaEl.checked ? 'Sim' : 'Não';
            if (ignoreAreaEl.checked) {
                selectedAreaId = null;
                document.getElementById('areaSelectorsContainer').style.display = 'none';
                document.getElementById('areaHint').style.display = 'none';
            } else {
                document.getElementById('areaSelectorsContainer').style.display = '';
                document.getElementById('areaHint').style.display = '';
                renderAreaSelectors(selectedAreaId);
            }
        });

        // 1) Descobrir quem é o usuário logado
        fetch('/bff/me')
            .then(function (r) { return r.json(); })
            .then(function (me) {
                currentUserId = me.id;
                isAdmin = me.userTypeValue === 3; // Administrator

                // Load sectors and areas
                var sectorsPromise = fetch('/bff/sectors').then(function (r) { return r.json(); });
                var areasPromise = fetch('/bff/areas').then(function (r) { return r.json(); });

                Promise.all([sectorsPromise, areasPromise])
                    .then(function (results) {
                        allSectors = results[0].filter(function (s) { return s.active; });
                        allAreas = results[1].filter(function (a) { return a.active; });
                        if (isAdmin) { initAdmin(); } else { initAndonUser(); }
                    })
                    .catch(function () {
                        if (isAdmin) { initAdmin(); } else { initAndonUser(); }
                    });
            })
            .catch(function () {
                document.getElementById('loadingState').style.display = 'none';
                document.getElementById('mainContent').style.display = '';
                showError('Erro ao carregar dados do usuário.');
            });

        // --- Modo Admin: mostrar seletor de usuários ---
        function initAdmin() {
            fetch('/bff/users/')
                .then(function (r) { return r.json(); })
                .then(function (users) {
                    var andonUsers = users.filter(function (u) { return u.userType === 1 && u.active; });
                    andonUsers.sort(function (a, b) { return a.name.localeCompare(b.name); });

                    document.getElementById('loadingState').style.display = 'none';
                    document.getElementById('mainContent').style.display = '';
                    document.getElementById('adminSection').style.display = '';

                    if (andonUsers.length === 0) {
                        document.getElementById('noUsersAlert').style.display = '';
                        return;
                    }

                    document.getElementById('userSelectRow').style.display = '';

                    andonUsers.forEach(function (u) {
                        var opt = document.createElement('option');
                        opt.value = u.id;
                        opt.textContent = u.name + ' (' + u.login + ')';
                        userSelect.appendChild(opt);
                    });
                })
                .catch(function () {
                    document.getElementById('loadingState').style.display = 'none';
                    document.getElementById('mainContent').style.display = '';
                    showError('Erro ao carregar usuários.');
                });

            userSelect.addEventListener('change', function () {
                selectedUserId = userSelect.value;
                document.getElementById('settingsForm').style.display = 'none';
                hideAlerts();

                if (!selectedUserId) return;

                loadSettings('/bff/andon-user-settings/' + selectedUserId);
            });
        }

        // --- Modo Andon User: carregar direto ---
        function initAndonUser() {
            selectedUserId = currentUserId;

            document.getElementById('loadingState').style.display = 'none';
            document.getElementById('mainContent').style.display = '';
            document.getElementById('andonUserSection').style.display = '';

            loadSettings('/bff/andon-user-settings');
        }

        // --- Carrega as configurações de um endpoint ---
        function loadSettings(url) {
            document.getElementById('settingsLoading').style.display = '';
            document.getElementById('settingsForm').style.display = 'none';
            selectedSectorIds = {};

            // Load settings and user data in parallel
            var settingsPromise = fetch(url).then(function (r) { return r.json(); });
            var userPromise = fetch('/bff/users/' + selectedUserId).then(function (r) { return r.json(); });

            Promise.all([settingsPromise, userPromise])
                .then(function (results) {
                    var data = results[0];
                    currentUserData = results[1];

                    document.getElementById('warningMinutes').value = data.warningMinutes || 30;
                    document.getElementById('criticalMinutes').value = data.criticalMinutes || 60;
                    document.getElementById('carouselInterval').value = data.carouselIntervalSeconds || 5;
                    showClockEl.checked = data.showClock !== false;
                    enableSoundEl.checked = !!data.enableSound;
                    document.getElementById('showClockLabel').textContent = showClockEl.checked ? 'Sim' : 'Não';
                    document.getElementById('enableSoundLabel').textContent = enableSoundEl.checked ? 'Sim' : 'Não';

                    // Load user's current sectors
                    if (currentUserData.sectors && currentUserData.sectors.length) {
                        currentUserData.sectors.forEach(function (s) {
                            selectedSectorIds[s.sectorId] = true;
                        });
                    }

                    // Load area selection
                    selectedAreaId = data.areaId || null;
                    ignoreAreaEl.checked = !selectedAreaId;
                    document.getElementById('ignoreAreaLabel').textContent = ignoreAreaEl.checked ? 'Sim' : 'Não';
                    if (ignoreAreaEl.checked) {
                        document.getElementById('areaSelectorsContainer').style.display = 'none';
                        document.getElementById('areaHint').style.display = 'none';
                    } else {
                        document.getElementById('areaSelectorsContainer').style.display = '';
                        document.getElementById('areaHint').style.display = '';
                    }
                    renderAreaSelectors(selectedAreaId);

                    renderSectors();

                    document.getElementById('settingsLoading').style.display = 'none';
                    document.getElementById('settingsForm').style.display = '';
                })
                .catch(function () {
                    document.getElementById('settingsLoading').style.display = 'none';
                    showError('Erro ao carregar configuração.');
                });
        }

        function escapeHtml(str) {
            var div = document.createElement('div');
            div.textContent = str || '';
            return div.innerHTML;
        }

        function isLightColor(hex) {
            hex = (hex || '').replace('#', '');
            if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
            var r = parseInt(hex.substr(0,2),16), g = parseInt(hex.substr(2,2),16), b = parseInt(hex.substr(4,2),16);
            return (r * 299 + g * 587 + b * 114) / 1000 > 155;
        }

        // --- Area hierarchy selectors ---
        // --- Area tree select ---
        function buildAreaTree(parentId, depth) {
            var items = [];
            var children = allAreas.filter(function (a) { return a.parentId === parentId; });
            children.forEach(function (a) {
                var prefix = '';
                for (var i = 0; i < depth; i++) prefix += '\u00A0\u00A0\u00A0\u00A0';
                if (depth > 0) prefix += '└ ';
                items.push({ id: a.id, label: prefix + a.name, depth: depth });
                var sub = buildAreaTree(a.id, depth + 1);
                items = items.concat(sub);
            });
            return items;
        }

        function renderAreaSelectors(currentAreaId) {
            var container = document.getElementById('areaSelectorsContainer');
            container.innerHTML = '';

            var select = document.createElement('select');
            select.className = 'form-control';

            var emptyOpt = document.createElement('option');
            emptyOpt.value = '';
            emptyOpt.textContent = '-- Todos os chamados --';
            select.appendChild(emptyOpt);

            var tree = buildAreaTree(null, 0);
            tree.forEach(function (item) {
                var opt = document.createElement('option');
                opt.value = item.id;
                opt.textContent = item.label;
                if (item.id === currentAreaId) opt.selected = true;
                select.appendChild(opt);
            });

            select.addEventListener('change', function () {
                selectedAreaId = select.value || null;
            });

            container.appendChild(select);

            if (currentAreaId) {
                var selectedArea = allAreas.find(function (a) { return a.id === currentAreaId; });
                if (selectedArea) {
                    var hasChildren = allAreas.some(function (a) { return a.parentId === currentAreaId; });
                    var hint = document.createElement('small');
                    hint.className = 'text-info d-block mt-1';
                    hint.innerHTML = '<i class="la la-info-circle"></i> ';
                    if (hasChildren) {
                        hint.innerHTML += 'Exibirá chamados de <strong>' + escapeHtml(selectedArea.name) + '</strong> e todos os seus subníveis.';
                    } else {
                        hint.innerHTML += 'Exibirá apenas chamados de <strong>' + escapeHtml(selectedArea.name) + '</strong>.';
                    }
                    container.appendChild(hint);
                }
            }
        }

        function renderSectors() {
            var container = document.getElementById('sectorList');
            container.innerHTML = '';

            if (allSectors.length === 0) {
                container.innerHTML = '<small class="text-muted">Nenhum setor cadastrado.</small>';
                return;
            }

            allSectors.forEach(function (sector) {
                var isSel = !!selectedSectorIds[sector.id];

                var label = document.createElement('label');
                label.className = 'sector-chip' + (isSel ? ' selected' : '');

                var cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.checked = isSel;

                var dot = document.createElement('span');
                dot.className = 'sector-dot';
                dot.style.backgroundColor = sector.color || '#ccc';

                var nameSpan = document.createElement('span');
                nameSpan.textContent = sector.name;

                label.appendChild(cb);
                label.appendChild(dot);
                label.appendChild(nameSpan);

                cb.addEventListener('change', function () {
                    if (cb.checked) { selectedSectorIds[sector.id] = true; }
                    else { delete selectedSectorIds[sector.id]; }
                    renderSectors();
                });

                container.appendChild(label);
            });
        }

        // --- Marcar/Desmarcar todos os setores ---
        document.getElementById('btnSelectAllSectors').addEventListener('click', function () {
            allSectors.forEach(function (s) { selectedSectorIds[s.id] = true; });
            renderSectors();
        });
        document.getElementById('btnDeselectAllSectors').addEventListener('click', function () {
            selectedSectorIds = {};
            renderSectors();
        });

        // --- Salvar ---
        saveBtn.addEventListener('click', function () {
            if (!selectedUserId) return;

            var w = parseInt(document.getElementById('warningMinutes').value);
            var c = parseInt(document.getElementById('criticalMinutes').value);
            var ci = parseInt(document.getElementById('carouselInterval').value);

            if (!w || w < 1 || w > 1440) { showError('Alerta Amarelo deve ser entre 1 e 1440 minutos.'); return; }
            if (!c || c < 1 || c > 1440) { showError('Alerta Vermelho deve ser entre 1 e 1440 minutos.'); return; }
            if (!ci || ci < 1 || ci > 120) { showError('Intervalo do Carrossel deve ser entre 1 e 120 segundos.'); return; }

            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i class="la la-spinner la-spin"></i> Salvando...';
            hideAlerts();

            var url = isAdmin
                ? '/bff/andon-user-settings/' + selectedUserId
                : '/bff/andon-user-settings';

            fetch(url, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    warningMinutes: w,
                    criticalMinutes: c,
                    carouselIntervalSeconds: ci,
                    showClock: showClockEl.checked,
                    enableSound: enableSoundEl.checked,
                    areaId: selectedAreaId || null
                })
            })
            .then(function (r) {
                if (!r.ok) {
                    return r.json().then(function (d) { showError(d.error || 'Erro ao salvar.'); throw new Error(); });
                }

                // Save sectors via dedicated endpoint
                var sectorIds = Object.keys(selectedSectorIds);
                return fetch('/bff/users/' + selectedUserId + '/sectors', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(sectorIds)
                });
            })
            .then(function (r) {
                if (r && !r.ok) {
                    return r.json().then(function (d) { showError(d.error || 'Erro ao salvar setores.'); });
                }
                var msg = isAdmin
                    ? 'Configuração de ' + userSelect.options[userSelect.selectedIndex].textContent + ' salva com sucesso.'
                    : 'Configuração salva com sucesso.';
                showSuccess(msg);
            })
            .catch(function () { showError('Erro ao salvar configuração.'); })
            .finally(function () {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="la la-check"></i> Salvar Configuração';
            });
        });

        function showSuccess(msg) {
            document.getElementById('alertSuccessText').textContent = msg;
            document.getElementById('alertSuccess').style.display = '';
            document.getElementById('alertError').style.display = 'none';
        }
        function showError(msg) {
            document.getElementById('alertErrorText').textContent = msg;
            document.getElementById('alertError').style.display = '';
            document.getElementById('alertSuccess').style.display = 'none';
        }
        function hideAlerts() {
            document.getElementById('alertSuccess').style.display = 'none';
            document.getElementById('alertError').style.display = 'none';
        }
    })();
</script>

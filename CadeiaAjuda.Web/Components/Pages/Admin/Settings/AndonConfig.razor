@page "/settings/andon"
@page "/andon/settings"

<PageTitle>Configuração do Andon - Cadeia Ajuda</PageTitle>

<section>
    <div class="row mb-2">
        <div class="col-12">
            <h4 class="content-header-title mb-0">Configuração do Andon</h4>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-content">
                    <div class="card-body">

                        <div id="loadingState" class="text-center py-3">
                            <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                        </div>

                        <div id="mainContent" style="display:none;">
                            <div id="alertSuccess" class="alert alert-success alert-dismissible mb-2" role="alert" style="display:none;">
                                <button type="button" class="close" onclick="document.getElementById('alertSuccess').style.display='none'"><span>&times;</span></button>
                                <i class="la la-check-circle"></i> <span id="alertSuccessText"></span>
                            </div>

                            <div id="alertError" class="alert alert-danger alert-dismissible mb-2" role="alert" style="display:none;">
                                <button type="button" class="close" onclick="document.getElementById('alertError').style.display='none'"><span>&times;</span></button>
                                <i class="la la-warning"></i> <span id="alertErrorText"></span>
                            </div>

                            <!-- Admin: seletor de usuário -->
                            <div id="adminSection" style="display:none;">
                                <p class="text-muted mb-2">
                                    Selecione um usuário do tipo Andon para configurar o painel dele.
                                </p>

                                <div id="noUsersAlert" class="alert alert-warning mb-2" style="display:none;">
                                    <i class="la la-info-circle"></i> Nenhum usuário do tipo Andon ativo encontrado.
                                </div>

                                <div id="userSelectRow" class="row mb-2" style="display:none;">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="ft-user"></i> Usuário Andon <span class="text-danger">*</span></label>
                                            <select class="form-control" id="userSelect">
                                                <option value="">-- Selecione --</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Andon user: descrição -->
                            <div id="andonUserSection" style="display:none;">
                                <p class="text-muted mb-2">
                                    Personalize o comportamento do painel Andon.
                                </p>
                            </div>

                            <div id="settingsLoading" class="text-center py-3" style="display:none;">
                                <i class="la la-spinner la-spin font-large-1"></i> Carregando configuração...
                            </div>

                            <div id="settingsForm" style="display:none;">
                                <h6 class="text-muted text-uppercase mt-2 mb-1"><i class="la la-bell"></i> Alertas de Urgência</h6>
                                <hr class="mt-0" />

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="la la-exclamation-triangle text-warning"></i> Alerta Amarelo (minutos) <span class="text-danger">*</span></label>
                                            <input type="number" class="form-control" id="warningMinutes" min="1" max="1440" />
                                            <small class="text-muted">Tempo para o card ficar com borda amarela/laranja.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="la la-exclamation-circle text-danger"></i> Alerta Vermelho (minutos) <span class="text-danger">*</span></label>
                                            <input type="number" class="form-control" id="criticalMinutes" min="1" max="1440" />
                                            <small class="text-muted">Tempo para o card ficar vermelho piscante.</small>
                                        </div>
                                    </div>
                                </div>

                                <h6 class="text-muted text-uppercase mt-2 mb-1"><i class="ft-monitor"></i> Exibição</h6>
                                <hr class="mt-0" />

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label><i class="ft-clock"></i> Intervalo do Carrossel (segundos) <span class="text-danger">*</span></label>
                                            <input type="number" class="form-control" id="carouselInterval" min="1" max="120" />
                                            <small class="text-muted">Tempo entre a troca automática dos cards.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="d-block"><i class="ft-eye"></i> Exibir Relógio</label>
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="showClock" />
                                                <label class="custom-control-label" for="showClock" id="showClockLabel">Sim</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="d-block"><i class="ft-volume-2"></i> Alerta Sonoro</label>
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="enableSound" />
                                                <label class="custom-control-label" for="enableSound" id="enableSoundLabel">Não</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-actions text-right mt-2">
                                    <button type="button" class="btn btn-warning" id="saveBtn">
                                        <i class="la la-check"></i> Salvar Configuração
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function () {
        var isAdmin = false;
        var currentUserId = '';
        var selectedUserId = '';

        var userSelect = document.getElementById('userSelect');
        var showClockEl = document.getElementById('showClock');
        var enableSoundEl = document.getElementById('enableSound');
        var saveBtn = document.getElementById('saveBtn');

        showClockEl.addEventListener('change', function () {
            document.getElementById('showClockLabel').textContent = showClockEl.checked ? 'Sim' : 'Não';
        });
        enableSoundEl.addEventListener('change', function () {
            document.getElementById('enableSoundLabel').textContent = enableSoundEl.checked ? 'Sim' : 'Não';
        });

        // 1) Descobrir quem é o usuário logado
        fetch('/bff/me')
            .then(function (r) { return r.json(); })
            .then(function (me) {
                currentUserId = me.id;
                isAdmin = me.userTypeValue === 3; // Administrator

                if (isAdmin) {
                    initAdmin();
                } else {
                    initAndonUser();
                }
            })
            .catch(function () {
                document.getElementById('loadingState').style.display = 'none';
                document.getElementById('mainContent').style.display = '';
                showError('Erro ao carregar dados do usuário.');
            });

        // --- Modo Admin: mostrar seletor de usuários ---
        function initAdmin() {
            fetch('/bff/users/')
                .then(function (r) { return r.json(); })
                .then(function (users) {
                    var andonUsers = users.filter(function (u) { return u.userType === 1 && u.active; });
                    andonUsers.sort(function (a, b) { return a.name.localeCompare(b.name); });

                    document.getElementById('loadingState').style.display = 'none';
                    document.getElementById('mainContent').style.display = '';
                    document.getElementById('adminSection').style.display = '';

                    if (andonUsers.length === 0) {
                        document.getElementById('noUsersAlert').style.display = '';
                        return;
                    }

                    document.getElementById('userSelectRow').style.display = '';

                    andonUsers.forEach(function (u) {
                        var opt = document.createElement('option');
                        opt.value = u.id;
                        opt.textContent = u.name + ' (' + u.login + ')';
                        userSelect.appendChild(opt);
                    });
                })
                .catch(function () {
                    document.getElementById('loadingState').style.display = 'none';
                    document.getElementById('mainContent').style.display = '';
                    showError('Erro ao carregar usuários.');
                });

            userSelect.addEventListener('change', function () {
                selectedUserId = userSelect.value;
                document.getElementById('settingsForm').style.display = 'none';
                hideAlerts();

                if (!selectedUserId) return;

                loadSettings('/bff/andon-user-settings/' + selectedUserId);
            });
        }

        // --- Modo Andon User: carregar direto ---
        function initAndonUser() {
            selectedUserId = currentUserId;

            document.getElementById('loadingState').style.display = 'none';
            document.getElementById('mainContent').style.display = '';
            document.getElementById('andonUserSection').style.display = '';

            loadSettings('/bff/andon-user-settings');
        }

        // --- Carrega as configurações de um endpoint ---
        function loadSettings(url) {
            document.getElementById('settingsLoading').style.display = '';
            document.getElementById('settingsForm').style.display = 'none';

            fetch(url)
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    document.getElementById('warningMinutes').value = data.warningMinutes || 30;
                    document.getElementById('criticalMinutes').value = data.criticalMinutes || 60;
                    document.getElementById('carouselInterval').value = data.carouselIntervalSeconds || 5;
                    showClockEl.checked = data.showClock !== false;
                    enableSoundEl.checked = !!data.enableSound;
                    document.getElementById('showClockLabel').textContent = showClockEl.checked ? 'Sim' : 'Não';
                    document.getElementById('enableSoundLabel').textContent = enableSoundEl.checked ? 'Sim' : 'Não';

                    document.getElementById('settingsLoading').style.display = 'none';
                    document.getElementById('settingsForm').style.display = '';
                })
                .catch(function () {
                    document.getElementById('settingsLoading').style.display = 'none';
                    showError('Erro ao carregar configuração.');
                });
        }

        // --- Salvar ---
        saveBtn.addEventListener('click', function () {
            if (!selectedUserId) return;

            var w = parseInt(document.getElementById('warningMinutes').value);
            var c = parseInt(document.getElementById('criticalMinutes').value);
            var ci = parseInt(document.getElementById('carouselInterval').value);

            if (!w || w < 1 || w > 1440) { showError('Alerta Amarelo deve ser entre 1 e 1440 minutos.'); return; }
            if (!c || c < 1 || c > 1440) { showError('Alerta Vermelho deve ser entre 1 e 1440 minutos.'); return; }
            if (!ci || ci < 1 || ci > 120) { showError('Intervalo do Carrossel deve ser entre 1 e 120 segundos.'); return; }

            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i class="la la-spinner la-spin"></i> Salvando...';
            hideAlerts();

            var url = isAdmin
                ? '/bff/andon-user-settings/' + selectedUserId
                : '/bff/andon-user-settings';

            fetch(url, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    warningMinutes: w,
                    criticalMinutes: c,
                    carouselIntervalSeconds: ci,
                    showClock: showClockEl.checked,
                    enableSound: enableSoundEl.checked
                })
            })
            .then(function (r) {
                if (r.ok) {
                    var msg = isAdmin
                        ? 'Configuração de ' + userSelect.options[userSelect.selectedIndex].textContent + ' salva com sucesso.'
                        : 'Configuração salva com sucesso.';
                    showSuccess(msg);
                } else {
                    return r.json().then(function (d) { showError(d.error || 'Erro ao salvar.'); });
                }
            })
            .catch(function () { showError('Erro ao salvar configuração.'); })
            .finally(function () {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="la la-check"></i> Salvar Configuração';
            });
        });

        function showSuccess(msg) {
            document.getElementById('alertSuccessText').textContent = msg;
            document.getElementById('alertSuccess').style.display = '';
            document.getElementById('alertError').style.display = 'none';
        }
        function showError(msg) {
            document.getElementById('alertErrorText').textContent = msg;
            document.getElementById('alertError').style.display = '';
            document.getElementById('alertSuccess').style.display = 'none';
        }
        function hideAlerts() {
            document.getElementById('alertSuccess').style.display = 'none';
            document.getElementById('alertError').style.display = 'none';
        }
    })();
</script>

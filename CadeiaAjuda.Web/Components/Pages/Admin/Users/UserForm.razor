@page "/admin/users/new"
@page "/admin/users/edit/{Id:guid}"
@inject UserApiClient Api
@inject RoleApiClient RoleApi
@inject AuthStateService Auth
@inject NavigationManager Navigation

<PageTitle>@(isEdit ? "Editar Usuário" : "Novo Usuário") - Cadeia Ajuda</PageTitle>

<section>
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">@(isEdit ? "Editar Usuário" : "Novo Usuário")</h4>
                </div>
                <div class="card-content">
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible mb-2" role="alert">
                                <button type="button" class="close" @onclick="() => errorMessage = null"><span>&times;</span></button>
                                <i class="la la-warning"></i> @errorMessage
                            </div>
                        }

                        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="userForm">
                            <DataAnnotationsValidator />

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Nome <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Name" class="form-control" placeholder="Nome completo" />
                                        <ValidationMessage For="() => model.Name" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>E-mail <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Email" class="form-control" placeholder="usuario@empresa.com" />
                                        <ValidationMessage For="() => model.Email" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Login <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Login" class="form-control" placeholder="login.usuario" />
                                        <ValidationMessage For="() => model.Login" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Senha @(isEdit ? "" : "*")</label>
                                        <InputText @bind-Value="model.Password" class="form-control" type="password"
                                                   placeholder="@(isEdit ? "Deixe vazio para manter a atual" : "Senha de acesso")" />
                                        @if (!isEdit)
                                        {
                                            <ValidationMessage For="() => model.Password" />
                                        }
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Telefone</label>
                                        <InputText @bind-Value="model.Phone" class="form-control" placeholder="(00) 00000-0000" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Perfil</label>
                                        <InputSelect @bind-Value="model.SelectedRoleId" class="form-control">
                                            <option value="">Sem perfil (acesso total)</option>
                                            @foreach (var role in availableRoles)
                                            {
                                                <option value="@role.Id">@role.Name</option>
                                            }
                                        </InputSelect>
                                        <small class="text-muted">Define as permissőes de acesso do usuário</small>
                                    </div>
                                </div>
                                @if (isEdit)
                                {
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Status</label>
                                            <InputSelect @bind-Value="model.ActiveValue" class="form-control">
                                                <option value="true">Ativo</option>
                                                <option value="false">Inativo</option>
                                            </InputSelect>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="form-actions text-right mt-2">
                                <NavLink href="/admin/users" class="btn btn-light mr-1">
                                    <i class="ft-x"></i> Cancelar
                                </NavLink>
                                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <i class="la la-spinner la-spin"></i>
                                    }
                                    <i class="la la-check"></i> @(isEdit ? "Salvar Alteraçőes" : "Cadastrar")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    [SupplyParameterFromForm]
    private UserFormModel model { get; set; } = new();
    private bool isEdit => Id.HasValue;
    private bool isSaving;
    private string? errorMessage;
    private List<RoleViewModel> availableRoles = [];

    protected override async Task OnInitializedAsync()
    {
        var currentUser = Auth.GetCurrentUser();
        if (currentUser is not null)
        {
            availableRoles = await RoleApi.GetByTenantIdAsync(currentUser.TenantId);
            availableRoles = availableRoles.Where(r => r.Active).ToList();
        }

        if (isEdit && string.IsNullOrEmpty(model.Name))
        {
            var user = await Api.GetByIdAsync(Id!.Value);
            if (user is not null)
            {
                model = new UserFormModel
                {
                    Name = user.Name,
                    Email = user.Email,
                    Phone = user.Phone,
                    Login = user.Login,
                    SelectedTenantId = user.TenantId.ToString(),
                    ActiveValue = user.Active.ToString().ToLower(),
                    SelectedRoleId = user.RoleId?.ToString() ?? ""
                };
            }
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;

        var currentUser = Auth.GetCurrentUser();
        if (currentUser is null)
        {
            errorMessage = "Usu\u00e1rio n\u00e3o autenticado.";
            isSaving = false;
            return;
        }

        if (!isEdit && string.IsNullOrWhiteSpace(model.Password))
        {
            errorMessage = "Informe a senha.";
            isSaving = false;
            return;
        }

        model.TenantId = currentUser.TenantId;
        model.SelectedTenantId = currentUser.TenantId.ToString();
        model.Active = bool.TryParse(model.ActiveValue, out var active) ? active : true;
        model.RoleId = Guid.TryParse(model.SelectedRoleId, out var roleId) ? roleId : null;

        HttpResponseMessage response;

        if (isEdit)
        {
            response = await Api.UpdateAsync(Id!.Value, model);
        }
        else
        {
            response = await Api.CreateAsync(model);
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/admin/users");
        }
        else
        {
            try
            {
                var body = await response.Content.ReadAsStringAsync();
                var error = System.Text.Json.JsonSerializer.Deserialize<ErrorResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                errorMessage = error?.Error ?? "Ocorreu um erro ao salvar.";
            }
            catch
            {
                errorMessage = "Ocorreu um erro ao salvar.";
            }
        }

        isSaving = false;
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
    }
}

@page "/user/users/new"
@page "/user/users/edit/{Id:guid}"
@layout AdminLayout

<PageTitle>Usuário - AssistChain</PageTitle>

@code {
    [Parameter]
    public Guid? Id { get; set; }
}

<style>
    .sector-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        background: #fff;
        border: 2px solid #e5e7eb;
        border-radius: 6px;
        cursor: pointer;
        font-size: .9rem;
        transition: all .15s;
        user-select: none;
        margin: 0;
    }
    .sector-chip:hover { border-color: #f57c00; background: #fff8f0; }
    .sector-chip.selected { border-color: #f57c00; background: #fff3e0; }
    .sector-chip input[type="checkbox"] { accent-color: #f57c00; }
    .sector-dot {
        display: inline-block;
        width: 12px; height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .sector-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fafafa;
        margin-bottom: 5px;
    }
</style>

<section>
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title" id="pageTitle">Novo Usuário</h4>
                </div>
                <div class="card-content">
                    <div class="card-body">

                        <div id="loadingArea" class="text-center py-3">
                            <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                        </div>

                        <div id="formArea" style="display:none;">
                            <div id="alertArea"></div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Nome <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="userName" placeholder="Nome completo" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>E-mail</label>
                                        <input type="email" class="form-control" id="userEmail" placeholder="usuario@empresa.com" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Login <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="userLogin" placeholder="login.usuario" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label id="passwordLabel">Senha <span class="text-danger">*</span></label>
                                        <input type="password" class="form-control" id="userPassword" placeholder="Senha de acesso" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Telefone</label>
                                        <input type="text" class="form-control" id="userPhone" placeholder="(00) 00000-0000" data-mask="phone" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Perfil</label>
                                        <select class="form-control" id="userRole">
                                            <option value="">— Sem perfil —</option>
                                        </select>
                                        <small class="text-muted">Define as permissões de acesso do usuário</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Tipo de Usuário</label>
                                        <select class="form-control" id="userType">
                                            <option value="0">Padrão</option>
                                            <option value="1">Andon</option>
                                            <option value="2">Gestor</option>
                                            <option value="3">Administrador</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4" id="statusRow" style="display:none;">
                                    <div class="form-group">
                                        <label>Status</label>
                                        <select class="form-control" id="userActive">
                                            <option value="true">Ativo</option>
                                            <option value="false">Inativo</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-12">
                                    <div class="form-group">
                                        <label>Setores</label>
                                        <div class="mb-1">
                                            <button type="button" class="btn btn-sm btn-outline-primary mr-1" id="btnSelectAllSectors">
                                                <i class="ft-check-square"></i> Marcar Todos
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnDeselectAllSectors">
                                                <i class="ft-square"></i> Desmarcar Todos
                                            </button>
                                        </div>
                                        <div class="sector-list" id="sectorList">
                                            <small class="text-muted">Carregando setores...</small>
                                        </div>
                                        <small class="text-muted">Selecione os setores que este usuário pode acessar</small>
                                    </div>
                                </div>
                            </div>

                            <hr />

                            <div class="form-actions text-right">
                                <a href="/user/users" class="btn btn-secondary mr-1">
                                    <i class="ft-x"></i> Cancelar
                                </a>
                                <button type="button" class="btn btn-warning" id="btnSave">
                                    <i class="la la-check"></i> Cadastrar
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script suppress-error="BL9992">
(function () {
    'use strict';

    // ---- Route ----
    var pathParts = window.location.pathname.split('/');
    var isEdit = pathParts.length >= 4 && pathParts[2] === 'users' && pathParts[3] === 'edit';
    var userId = isEdit && pathParts.length >= 5 ? pathParts[4] : null;

    // ---- State ----
    var currentUser = null;
    var allSectors = [];
    var selectedSectorIds = {};

    // ---- DOM helpers ----
    function $(id) { return document.getElementById(id); }

    function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str || '';
        return div.innerHTML;
    }

    function showAlert(msg, type) {
        $('alertArea').innerHTML =
            '<div class="alert alert-' + type + ' alert-dismissible mb-2" role="alert">' +
            '<button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>' +
            '<i class="la la-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + '"></i> ' + escapeHtml(msg) +
            '</div>';
    }

    async function fetchJson(url) {
        var resp = await fetch(url);
        if (!resp.ok) throw new Error('Erro ao carregar');
        return await resp.json();
    }

    // ---- Render Sectors ----
    function renderSectors() {
        var container = $('sectorList');
        container.innerHTML = '';

        if (allSectors.length === 0) {
            container.innerHTML = '<small class="text-muted">Nenhum setor cadastrado.</small>';
            return;
        }

        allSectors.forEach(function (sector) {
            var isSelected = !!selectedSectorIds[sector.id];

            var label = document.createElement('label');
            label.className = 'sector-chip' + (isSelected ? ' selected' : '');

            var cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.checked = isSelected;

            var dot = document.createElement('span');
            dot.className = 'sector-dot';
            dot.style.backgroundColor = sector.color || '#ccc';

            var nameSpan = document.createElement('span');
            nameSpan.textContent = sector.name;

            label.appendChild(cb);
            label.appendChild(dot);
            label.appendChild(nameSpan);

            cb.addEventListener('change', function () {
                if (cb.checked) {
                    selectedSectorIds[sector.id] = true;
                } else {
                    delete selectedSectorIds[sector.id];
                }
                renderSectors();
            });

            container.appendChild(label);
        });
    }

    // ---- Select/Deselect All Sectors ----
    $('btnSelectAllSectors').addEventListener('click', function () {
        allSectors.forEach(function (s) { selectedSectorIds[s.id] = true; });
        renderSectors();
    });
    $('btnDeselectAllSectors').addEventListener('click', function () {
        selectedSectorIds = {};
        renderSectors();
    });

    // ---- Save ----
    $('btnSave').addEventListener('click', async function () {
        var name = $('userName').value.trim();
        var login = $('userLogin').value.trim();
        var password = $('userPassword').value;
        var email = $('userEmail').value.trim();
        var phone = $('userPhone').value.trim();
        var roleId = $('userRole').value || null;
        var userType = parseInt($('userType').value, 10);
        var active = $('userActive').value === 'true';

        $('alertArea').innerHTML = '';

        if (!name) { showAlert('Informe o nome do usuário.', 'danger'); return; }
        if (!login) { showAlert('Informe o login.', 'danger'); return; }
        if (!isEdit && !password) { showAlert('Informe a senha.', 'danger'); return; }
        if (!currentUser) { showAlert('Sessão expirada. Faça login novamente.', 'danger'); return; }

        var sectorIds = Object.keys(selectedSectorIds);

        var payload = {
            name: name,
            email: email,
            phone: phone,
            login: login,
            tenantId: currentUser.tenantId,
            roleId: roleId,
            userType: userType,
            sectorIds: sectorIds
        };

        if (isEdit) {
            payload.id = userId;
            payload.active = active;
            if (password) payload.password = password;
        } else {
            payload.password = password;
        }

        var btn = $('btnSave');
        btn.disabled = true;
        btn.innerHTML = '<i class="la la-spinner la-spin"></i> Salvando...';

        try {
            var url = isEdit ? '/bff/users/' + userId : '/bff/users';
            var method = isEdit ? 'PUT' : 'POST';

            var resp = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (resp.ok) {
                window.location.href = '/user/users';
            } else {
                var body = {};
                try { body = await resp.json(); } catch (e) { }
                showAlert(body.error || 'Erro ao salvar o usuário.', 'danger');
            }
        } catch (e) {
            showAlert('Erro de conexão.', 'danger');
        }

        btn.disabled = false;
        btn.innerHTML = '<i class="la la-check"></i> ' + (isEdit ? 'Salvar Alterações' : 'Cadastrar');
    });

    // ---- Init ----
    (async function init() {
        try {
            // Reset UI
            $('pageTitle').textContent = 'Novo Usuário';
            $('statusRow').style.display = 'none';
            $('userName').value = '';
            $('userEmail').value = '';
            $('userLogin').value = '';
            $('userPassword').value = '';
            $('userPhone').value = '';
            $('userRole').value = '';
            $('userType').value = '0';
            $('userActive').value = 'true';
            $('alertArea').innerHTML = '';
            $('loadingArea').style.display = '';
            $('formArea').style.display = 'none';
            $('btnSave').innerHTML = '<i class="la la-check"></i> Cadastrar';
            $('passwordLabel').innerHTML = 'Senha <span class="text-danger">*</span>';
            $('userPassword').placeholder = 'Senha de acesso';

            // Load current user
            try { currentUser = await fetchJson('/bff/me'); } catch (e) { currentUser = null; }

            if (!currentUser) {
                $('loadingArea').innerHTML = '<div class="alert alert-danger">Sessão expirada.</div>';
                return;
            }

            // Permission check
            if (currentUser.userTypeValue !== 3 && (!currentUser.permissions || currentUser.permissions.indexOf('users.manage') < 0)) {
                window.location.href = '/user/users';
                return;
            }

            // Load roles and sectors in parallel
            var rolesPromise = fetchJson('/bff/roles');
            var sectorsPromise = fetchJson('/bff/sectors');

            var roles = await rolesPromise;
            allSectors = (await sectorsPromise).filter(function (s) { return s.active; });

            // Populate role dropdown
            var roleSelect = $('userRole');
            roleSelect.innerHTML = '<option value="">— Sem perfil —</option>';
            roles.filter(function (r) { return r.active; }).forEach(function (r) {
                var opt = document.createElement('option');
                opt.value = r.id;
                opt.textContent = r.name;
                roleSelect.appendChild(opt);
            });

            // If editing, load user data
            if (isEdit && userId) {
                $('pageTitle').textContent = 'Editar Usuário';
                $('statusRow').style.display = '';
                $('btnSave').innerHTML = '<i class="la la-check"></i> Salvar Alterações';
                $('passwordLabel').innerHTML = 'Senha';
                $('userPassword').placeholder = 'Deixe vazio para manter a atual';

                var user = await fetchJson('/bff/users/' + userId);
                $('userName').value = user.name || '';
                $('userEmail').value = user.email || '';
                $('userLogin').value = user.login || '';
                $('userPhone').value = user.phone || '';
                $('userRole').value = user.roleId || '';
                $('userType').value = (user.userType != null ? user.userType : 0).toString();
                $('userActive').value = user.active ? 'true' : 'false';

                // Load selected sectors
                if (user.sectors && user.sectors.length) {
                    user.sectors.forEach(function (s) {
                        selectedSectorIds[s.sectorId] = true;
                    });
                }
            }

            renderSectors();

            $('loadingArea').style.display = 'none';
            $('formArea').style.display = '';
        } catch (e) {
            $('loadingArea').innerHTML =
                '<div class="alert alert-danger"><i class="la la-exclamation-circle"></i> Erro ao carregar dados. Recarregue a página.</div>';
        }
    })();
})();
</script>

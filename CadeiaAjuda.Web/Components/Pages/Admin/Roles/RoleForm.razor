@page "/admin/roles/new"
@page "/admin/roles/edit/{Id:guid}"
@inject RoleApiClient RoleApi
@inject AuthStateService Auth
@inject NavigationManager Navigation

<PageTitle>@(isEdit ? "Editar" : "Novo") Perfil - Cadeia Ajuda</PageTitle>

<section>
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">@(isEdit ? "Editar" : "Novo") Perfil</h4>
                </div>
                <div class="card-content">
                    <div class="card-body">
                        @if (isLoading)
                        {
                            <div class="text-center py-3">
                                <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                            </div>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger mb-2">
                                    <i class="la la-exclamation-circle"></i> @errorMessage
                                </div>
                            }

                            <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="roleForm">
                                <DataAnnotationsValidator />

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Nome do Perfil <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="model.Name" class="form-control" placeholder="Ex: Operador, Supervisor, Administrador" />
                                            <ValidationMessage For="@(() => model.Name)" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Descrição</label>
                                            <InputText @bind-Value="model.Description" class="form-control" placeholder="Descrição do perfil" />
                                        </div>
                                    </div>
                                </div>

                                @if (isEdit)
                                {
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="form-group">
                                                <label>Status</label>
                                                <select class="form-control" @bind="model.ActiveValue">
                                                    <option value="true">Ativo</option>
                                                    <option value="false">Inativo</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </EditForm>

                            <div @key="permissionsRenderKey">
                                <hr />

                                <h5 class="mb-3"><i class="la la-shield"></i> Permissões</h5>

                                <div class="mb-3">
                                    <button type="button" class="btn btn-sm btn-outline-primary mr-1" @onclick="SelectAll">
                                        <i class="ft-check-square"></i> Marcar Todas
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="DeselectAll">
                                        <i class="ft-square"></i> Desmarcar Todas
                                    </button>
                                    <span class="ml-2 text-muted">@selectedPermissions.Count de @allPermissions.Count selecionadas</span>
                                </div>

                                @foreach (var group in permissionGroups)
                                {
                                    var groupKey = group.Key;
                                    var groupPerms = group.Value;
                                    var groupSelectedCount = groupPerms.Count(p => selectedPermissions.Contains(p.Key));
                                    var allGroupSelected = groupSelectedCount == groupPerms.Count;

                                    <div class="card mb-2">
                                        <div class="card-header py-2 d-flex align-items-center justify-content-between"
                                             style="background:#f8f9fa;cursor:pointer;"
                                             @onclick="() => ToggleGroup(groupKey)">
                                            <h6 class="mb-0">
                                                <i class="la @(IsGroupExpanded(groupKey) ? "la-angle-down" : "la-angle-right") mr-1"></i>
                                                @groupKey
                                                <span class="badge badge-light ml-1">@groupSelectedCount / @groupPerms.Count</span>
                                            </h6>
                                            <button type="button" class="btn btn-sm btn-link p-0" @onclick="() => ToggleGroupAll(groupKey)" @onclick:stopPropagation="true">
                                                @if (allGroupSelected)
                                                {
                                                    <span class="text-muted">Desmarcar grupo</span>
                                                }
                                                else
                                                {
                                                    <span class="text-primary">Marcar grupo</span>
                                                }
                                            </button>
                                        </div>
                                        @if (IsGroupExpanded(groupKey))
                                        {
                                            <div class="card-body py-2">
                                                <div class="row">
                                                    @foreach (var perm in groupPerms)
                                                    {
                                                        var pk = perm.Key;
                                                        var selected = selectedPermissions.Contains(pk);
                                                        <div class="col-md-4 col-sm-6 col-12 mb-1">
                                                            <div class="perm-item @(selected ? "perm-selected" : "")"
                                                                 @onclick="() => TogglePermission(pk)">
                                                                <span class="perm-check">
                                                                    @if (selected)
                                                                    {
                                                                        <i class="la la-check-square text-primary"></i>
                                                                    }
                                                                    else
                                                                    {
                                                                        <i class="la la-square-o text-muted"></i>
                                                                    }
                                                                </span>
                                                                <span>
                                                                    <span class="perm-label">@perm.Name</span>
                                                                    <small class="perm-key text-muted d-block">@pk</small>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <hr />

                            <div class="form-actions text-right">
                                <NavLink href="/admin/roles" class="btn btn-secondary mr-1">
                                    <i class="ft-x"></i> Cancelar
                                </NavLink>
                                <button type="button" class="btn btn-primary" disabled="@isSaving" @onclick="HandleSubmit">
                                    @if (isSaving)
                                    {
                                        <i class="la la-spinner la-spin"></i>
                                    }
                                    else
                                    {
                                        <i class="la la-check"></i>
                                    }
                                    Salvar
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .perm-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        cursor: pointer;
        padding: 8px 10px;
        border-radius: 6px;
        border: 2px solid transparent;
        transition: all .15s;
        user-select: none;
    }

    .perm-item:hover {
        background: #f0f4ff;
    }

    .perm-item.perm-selected {
        background: #e8f4fd;
        border-color: #1e9ff2;
    }

    .perm-check {
        font-size: 1.3rem;
        line-height: 1;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .perm-label {
        font-weight: 600;
        font-size: .9rem;
    }

    .perm-key {
        font-size: .75rem;
    }
</style>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private bool isEdit => Id.HasValue;
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;

    private RoleFormModel model = new();
    private List<PermissionViewModel> allPermissions = [];
    private Dictionary<string, List<PermissionViewModel>> permissionGroups = new();
    private HashSet<string> selectedPermissions = new();
    private HashSet<string> expandedGroups = new();
    private int permissionsRenderKey;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        allPermissions = await RoleApi.GetAllPermissionsAsync();
        permissionGroups = allPermissions
            .GroupBy(p => p.Group)
            .OrderBy(g => g.Min(p => p.SortOrder))
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.SortOrder).ToList());

        expandedGroups = new HashSet<string>(permissionGroups.Keys);

        if (isEdit)
        {
            var role = await RoleApi.GetByIdAsync(Id!.Value);
            if (role is not null)
            {
                model.Name = role.Name;
                model.Description = role.Description;
                model.ActiveValue = role.Active ? "true" : "false";
                selectedPermissions = new HashSet<string>(role.Permissions);
            }
        }

        RefreshPermissionsUI();
        isLoading = false;
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = "Informe o nome do perfil.";
            isSaving = false;
            return;
        }

        var currentUser = Auth.GetCurrentUser();
        if (currentUser is null)
        {
            errorMessage = "Sessão expirada.";
            isSaving = false;
            return;
        }

        var saveModel = new RoleSaveModel
        {
            Name = model.Name,
            Description = model.Description,
            TenantId = currentUser.TenantId,
            Active = model.ActiveValue == "true",
            Permissions = selectedPermissions.ToList()
        };

        HttpResponseMessage response;
        if (isEdit)
            response = await RoleApi.UpdateAsync(Id!.Value, saveModel);
        else
            response = await RoleApi.CreateAsync(saveModel);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/admin/roles", forceLoad: true);
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();
            errorMessage = body.Contains("error")
                ? "Já existe um perfil com este nome."
                : "Erro ao salvar o perfil.";
        }

        isSaving = false;
    }

    private void TogglePermission(string key)
    {
        if (!selectedPermissions.Remove(key))
            selectedPermissions.Add(key);
        RefreshPermissionsUI();
    }

    private void SelectAll()
    {
        foreach (var p in allPermissions)
            selectedPermissions.Add(p.Key);
        RefreshPermissionsUI();
    }

    private void DeselectAll()
    {
        selectedPermissions.Clear();
        RefreshPermissionsUI();
    }

    private void ToggleGroup(string groupName)
    {
        if (expandedGroups.Contains(groupName))
            expandedGroups.Remove(groupName);
        else
            expandedGroups.Add(groupName);
        RefreshPermissionsUI();
    }

    private bool IsGroupExpanded(string groupName)
        => expandedGroups.Contains(groupName);

    private void ToggleGroupAll(string groupName)
    {
        if (!permissionGroups.TryGetValue(groupName, out var perms)) return;

        var allSelected = perms.All(p => selectedPermissions.Contains(p.Key));
        foreach (var p in perms)
        {
            if (allSelected)
                selectedPermissions.Remove(p.Key);
            else
                selectedPermissions.Add(p.Key);
        }

        RefreshPermissionsUI();
    }

    private void RefreshPermissionsUI()
    {
        permissionsRenderKey++;
        StateHasChanged();
    }

    private sealed class RoleFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Informe o nome do perfil.")]
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string ActiveValue { get; set; } = "true";
    }
}

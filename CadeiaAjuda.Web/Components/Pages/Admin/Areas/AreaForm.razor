@page "/admin/areas/new"
@page "/admin/areas/new"
@page "/admin/areas/edit/{Id:guid}"
@inject AreaApiClient Api
@inject NavigationManager Navigation

<PageTitle>@(isEdit ? "Editar Área" : "Nova Área") - Cadeia Ajuda</PageTitle>

<section>
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">@(isEdit ? "Editar Área" : "Nova Área")</h4>
                </div>
                <div class="card-content">
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible mb-2" role="alert">
                                <button type="button" class="close" @onclick="() => errorMessage = null"><span>&times;</span></button>
                                <i class="la la-warning"></i> @errorMessage
                            </div>
                        }

                        @if (isLoadingData)
                        {
                            <div class="text-center py-3">
                                <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                            </div>
                        }
                        else
                        {
                            <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="areaForm">
                                <DataAnnotationsValidator />

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Nome da Área <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="model.Name" class="form-control" placeholder="Ex: Fábrica, Planta A, Linha 1, Posto 1A..." />
                                            <ValidationMessage For="() => model.Name" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Área Pai</label>
                                            <select class="form-control" @bind="selectedParentId">
                                                <option value="">— Nenhuma (área raiz) —</option>
                                                @foreach (var option in parentOptions)
                                                {
                                                    <option value="@option.Id">@option.DisplayName</option>
                                                }
                                            </select>
                                            <small class="text-muted">Selecione a área ŕ qual esta pertence, ou deixe vazio para criar uma área raiz.</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label>Descriçăo</label>
                                            <InputText @bind-Value="model.Description" class="form-control" placeholder="Descriçăo da área (opcional)" />
                                        </div>
                                    </div>
                                    @if (isEdit)
                                    {
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Status</label>
                                                <select class="form-control" @bind="activeValue">
                                                    <option value="true">Ativo</option>
                                                    <option value="false">Inativo</option>
                                                </select>
                                            </div>
                                        </div>
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(parentPath))
                                {
                                    <div class="alert alert-info py-2 mb-3">
                                        <i class="la la-sitemap"></i> <strong>Hierarquia:</strong> @parentPath > <em>@(string.IsNullOrEmpty(model.Name) ? "Nova Área" : model.Name)</em>
                                    </div>
                                }

                                <div class="form-actions text-right mt-2">
                                    <NavLink href="/admin/areas" class="btn btn-light mr-1">
                                        <i class="ft-x"></i> Cancelar
                                    </NavLink>
                                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <i class="la la-spinner la-spin"></i>
                                        }
                                        <i class="la la-check"></i> @(isEdit ? "Salvar Alteraçőes" : "Cadastrar")
                                    </button>
                                </div>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    [SupplyParameterFromQuery]
    public string? parentId { get; set; }

    private AreaFormModel model = new();
    private bool isEdit => Id.HasValue;
    private bool isSaving;
    private bool isLoadingData = true;
    private string? errorMessage;
    private string activeValue = "true";
    private string selectedParentId = "";
    private string parentPath = "";

    private List<AreaViewModel> allAreas = [];
    private List<ParentOption> parentOptions = [];

    protected override async Task OnInitializedAsync()
    {
        allAreas = await Api.GetAllAsync();
        BuildParentOptions();

        if (isEdit)
        {
            var area = await Api.GetByIdAsync(Id!.Value);
            if (area is not null)
            {
                model = new AreaFormModel
                {
                    Name = area.Name,
                    Description = area.Description,
                    ParentId = area.ParentId,
                    Active = area.Active
                };
                selectedParentId = area.ParentId?.ToString() ?? "";
                activeValue = area.Active.ToString().ToLower();
                UpdateParentPath();
            }
        }
        else if (!string.IsNullOrEmpty(parentId) && Guid.TryParse(parentId, out var pid))
        {
            selectedParentId = pid.ToString();
            model.ParentId = pid;
            UpdateParentPath();
        }

        isLoadingData = false;
    }

    private void BuildParentOptions()
    {
        parentOptions = [];
        var roots = allAreas.Where(a => a.ParentId == null).ToList();
        foreach (var root in roots)
        {
            // Năo permitir selecionar a si mesmo como pai (no modo ediçăo)
            if (isEdit && root.Id == Id!.Value) continue;
            parentOptions.Add(new ParentOption { Id = root.Id, DisplayName = root.Name });
            AddChildOptions(root.Id, root.Name, 1);
        }
    }

    private void AddChildOptions(Guid parentId, string prefix, int level)
    {
        var children = allAreas.Where(a => a.ParentId == parentId).ToList();
        foreach (var child in children)
        {
            if (isEdit && child.Id == Id!.Value) continue;
            // Verificar se é descendente do próprio item (evitar ciclo)
            if (isEdit && IsDescendantOf(child.Id, Id!.Value)) continue;

            var indent = new string('—', level);
            parentOptions.Add(new ParentOption { Id = child.Id, DisplayName = $"{indent} {child.Name}" });
            AddChildOptions(child.Id, $"{prefix} > {child.Name}", level + 1);
        }
    }

    private bool IsDescendantOf(Guid areaId, Guid potentialAncestorId)
    {
        var children = allAreas.Where(a => a.ParentId == potentialAncestorId);
        foreach (var child in children)
        {
            if (child.Id == areaId) return true;
            if (IsDescendantOf(areaId, child.Id)) return true;
        }
        return false;
    }

    private void UpdateParentPath()
    {
        if (Guid.TryParse(selectedParentId, out var pid))
        {
            var parts = new List<string>();
            var current = allAreas.FirstOrDefault(a => a.Id == pid);
            while (current is not null)
            {
                parts.Insert(0, current.Name);
                current = current.ParentId.HasValue
                    ? allAreas.FirstOrDefault(a => a.Id == current.ParentId.Value)
                    : null;
            }
            parentPath = string.Join(" > ", parts);
        }
        else
        {
            parentPath = "";
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;

        model.ParentId = Guid.TryParse(selectedParentId, out var pid) ? pid : null;
        model.Active = bool.Parse(activeValue);

        HttpResponseMessage response;

        if (isEdit)
        {
            response = await Api.UpdateAsync(Id!.Value, model);
        }
        else
        {
            response = await Api.CreateAsync(model);
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/admin/areas");
        }
        else
        {
            errorMessage = "Ocorreu um erro ao salvar a área. Tente novamente.";
        }

        isSaving = false;
    }

    private class ParentOption
    {
        public Guid Id { get; set; }
        public string DisplayName { get; set; } = string.Empty;
    }
}

@page "/admin/areas"
@inject AreaApiClient Api

<PageTitle>Áreas - Cadeia Ajuda</PageTitle>

<section>
    <div class="row mb-2">
        <div class="col-12">
            <NavLink href="/admin/areas/new" class="btn btn-primary btn-icon mr-1" title="Adicionar área">
                <i class="ft-plus"></i>
            </NavLink>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-2" role="alert">
            <button type="button" class="close" @onclick="() => successMessage = null"><span>&times;</span></button>
            <i class="la la-check-circle"></i> @successMessage
        </div>
    }

    <div class="card">
        <div class="card-content">
            <div class="card-body">
                @if (isLoading)
                {
                    <div class="text-center py-3">
                        <i class="la la-spinner la-spin font-large-1"></i> Carregando...
                    </div>
                }
                else if (!FilteredRoots.Any())
                {
                    <div class="text-center py-3 text-muted">
                        Nenhuma área encontrada.
                    </div>
                }
                else
                {
                    <div class="area-tree">
                        @foreach (var area in FilteredRoots)
                        {
                            @RenderTreeNode(area, 0)
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    .area-tree-node {
        margin-bottom: 4px;
    }

    .area-tree-header {
        display: flex;
        align-items: center;
        padding: 10px 12px;
        gap: 8px;
        border: 1px solid #e4e7ed;
        border-radius: 5px;
        background: #fff;
        transition: background-color 0.15s;
    }

    .area-tree-header:hover {
        background-color: #f5f7fa;
    }

    .area-tree-toggle {
        background: none;
        border: none;
        padding: 2px 6px;
        cursor: pointer;
        color: #6b6f82;
        font-size: 0.9rem;
        min-width: 24px;
    }

    .area-tree-toggle:hover {
        color: #1e9ff2;
    }

    .area-tree-toggle .ft-chevron-right {
        transition: transform 0.2s;
    }

    .area-tree-toggle[aria-expanded="true"] .ft-chevron-right {
        transform: rotate(90deg);
    }

    .area-tree-name {
        font-weight: 600;
        color: #404e67;
    }

    .area-tree-desc {
        color: #8d9daa;
        font-size: 0.85rem;
    }

    .area-tree-actions {
        margin-left: auto;
        display: flex;
        gap: 4px;
    }

    .area-tree-actions .btn {
        padding: 2px 8px;
        font-size: 0.85rem;
    }

    .area-tree-children {
        margin-left: 28px;
        border-left: 2px solid #e4e7ed;
        padding-left: 8px;
        padding-top: 4px;
    }

    .area-leaf-icon {
        color: #b3bac5;
        min-width: 24px;
        text-align: center;
    }

    .area-node-badge {
        font-size: 0.75rem;
        padding: 2px 8px;
        border-radius: 10px;
    }
</style>

@code {
private List<AreaViewModel> filteredAreas = [];
private bool isLoading = true;
private string? successMessage;

private IEnumerable<AreaViewModel> FilteredRoots =>
    filteredAreas.Where(a => a.ParentId == null || !filteredAreas.Any(p => p.Id == a.ParentId));

protected override async Task OnInitializedAsync()
{
    await LoadAreasAsync();
}

private async Task LoadAreasAsync()
{
    isLoading = true;
    filteredAreas = await Api.GetAllAsync();
    isLoading = false;
}

    private List<AreaViewModel> GetChildren(Guid parentId) =>
        filteredAreas.Where(a => a.ParentId == parentId).ToList();

    private RenderFragment RenderTreeNode(AreaViewModel area, int level) => __builder =>
    {
        var children = GetChildren(area.Id);
        var hasChildren = children.Any();
        var collapseId = $"area-collapse-{area.Id.ToString("N")}";

        <div class="area-tree-node">
            <div class="area-tree-header">
                @if (hasChildren)
                {
                    <a class="area-tree-toggle" data-toggle="collapse" href="#@collapseId"
                       aria-expanded="true" aria-controls="@collapseId" title="Expandir/Recolher">
                        <i class="ft-chevron-right"></i>
                    </a>
                }
                else
                {
                    <span class="area-leaf-icon">
                        <i class="ft-circle" style="font-size: 0.5rem;"></i>
                    </span>
                }

                <span class="area-tree-name">@area.Name</span>

                @if (!string.IsNullOrEmpty(area.Description))
                {
                    <span class="area-tree-desc">— @area.Description</span>
                }

                @if (hasChildren)
                {
                    <span class="area-node-badge badge badge-light">
                        @children.Count sub-área(s)
                    </span>
                }
                else
                {
                    <span class="area-node-badge badge badge-info">
                        <i class="ft-target" style="font-size: 0.65rem;"></i> nó final
                    </span>
                }

                @if (area.Active)
                {
                    <span class="badge badge-success" style="font-size: 0.7rem;">Ativo</span>
                }
                else
                {
                    <span class="badge badge-danger" style="font-size: 0.7rem;">Inativo</span>
                }

                <div class="area-tree-actions">
                    <NavLink href="@($"/admin/areas/new?parentId={area.Id}")" class="btn btn-sm btn-outline-primary" title="Adicionar sub-área">
                        <i class="ft-plus"></i>
                    </NavLink>
                    <NavLink href="@($"/admin/areas/edit/{area.Id}")" class="btn btn-sm btn-outline-info" title="Editar">
                        <i class="ft-edit-2"></i>
                    </NavLink>
                    <button class="btn btn-sm @(area.Active ? "btn-outline-warning" : "btn-outline-success")"
                            title="@(area.Active ? "Inativar" : "Ativar")"
                            @onclick="() => ToggleActive(area)">
                        <i class="ft-power"></i>
                    </button>
                </div>
            </div>

            @if (hasChildren)
            {
                <div class="collapse show area-tree-children" id="@collapseId">
                    @foreach (var child in children)
                    {
                        @RenderTreeNode(child, level + 1)
                    }
                </div>
            }
        </div>
    };

    private async Task ToggleActive(AreaViewModel area)
    {
        var response = await Api.ToggleActiveAsync(area.Id);
        if (response.IsSuccessStatusCode)
        {
            area.Active = !area.Active;
            successMessage = $"Área \"{area.Name}\" {(area.Active ? "ativada" : "inativada")} com sucesso.";
        }
    }
}

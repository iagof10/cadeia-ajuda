@page "/register/plants"
@layout AdminLayout

<PageTitle>Plantas - Cadeia Ajuda</PageTitle>

<style>
    /* Tree */
    .area-tree-node { margin-bottom:4px; }
    .area-tree-header { display:flex; align-items:center; padding:10px 12px; gap:8px; border:1px solid #e4e7ed; border-radius:5px; background:#fff; transition:background-color .15s; }
    .area-tree-header:hover { background-color:#f5f7fa; }
    .area-tree-toggle { background:none; border:none; padding:2px 6px; cursor:pointer; color:#6b6f82; font-size:.9rem; min-width:24px; }
    .area-tree-toggle:hover { color:#1e9ff2; }
    .area-tree-toggle .ft-chevron-right { transition:transform .2s; display:inline-block; }
    .area-tree-toggle.expanded .ft-chevron-right { transform:rotate(90deg); }
    .area-tree-name { font-weight:600; color:#404e67; }
    .area-tree-desc { color:#8d9daa; font-size:.85rem; }
    .area-tree-actions { margin-left:auto; display:flex; gap:4px; }
    .area-tree-actions .btn { padding:2px 8px; font-size:.85rem; }
    .area-tree-children { margin-left:28px; border-left:2px solid #e4e7ed; padding-left:8px; padding-top:4px; }
    .area-leaf-icon { color:#b3bac5; min-width:24px; text-align:center; }
    .area-node-badge { font-size:.75rem; padding:2px 8px; border-radius:10px; }

    /* Modal */
    .modal-section { background:#f8f9fa; border-radius:8px; padding:1rem 1.25rem; margin-bottom:1rem; }
    .modal-section-title { font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#1e9ff2; margin-bottom:.75rem; display:flex; align-items:center; gap:.4rem; }
    .modal-section-title i { font-size:1rem; }
    #areaModal .modal-header { border-bottom:none; padding-bottom:0; }
    #areaModal .modal-footer { border-top:none; padding-top:0; }
    #areaModal .modal-title { font-weight:700; }
    #areaModal .form-control { border-radius:6px; border:1px solid #e0e5ec; transition:border-color .2s,box-shadow .2s; }
    #areaModal .form-control:focus { border-color:#1e9ff2; box-shadow:0 0 0 3px rgba(30,159,242,.12); }
    #areaModal label { font-size:.85rem; font-weight:600; color:#555; margin-bottom:.3rem; }

    .hierarchy-preview { background:#e8f4fd; border-radius:6px; padding:.5rem .75rem; font-size:.85rem; color:#1565c0; }
    .hierarchy-preview i { margin-right:4px; }
</style>

<div class="row mb-2">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h4 class="content-header-title mb-0">Plantas</h4>
        </div>
        <button class="btn btn-warning" id="btnAddRoot" type="button">
            <i class="ft-plus"></i> Nova Planta
        </button>
    </div>
</div>

<div id="alertArea"></div>

<div id="loadingArea" class="text-center py-3">
    <i class="la la-spinner la-spin font-large-1"></i> Carregando...
</div>

<div id="emptyState" style="display:none;">
    <div class="card">
        <div class="card-body text-center text-muted py-4">
            <i class="la la-map font-large-2 d-block mb-1"></i>
            Nenhuma planta cadastrada. Clique em "Nova Planta" para começar.
        </div>
    </div>
</div>

<div class="card" id="treeCard" style="display:none;">
    <div class="card-body">
        <div id="treeContainer" class="area-tree"></div>
    </div>
</div>

<!-- Modal Add/Edit -->
<div class="modal fade" id="areaModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content" style="border:none;border-radius:12px;overflow:hidden;">
            <div class="modal-header" style="padding:1.25rem 1.5rem .75rem;">
                <div>
                    <h5 class="modal-title" id="modalTitle" style="margin-bottom:2px;">Nova Planta</h5>
                    <small class="text-muted" id="modalSubtitle">Preencha os dados abaixo.</small>
                </div>
                <button type="button" class="close" data-dismiss="modal" style="margin-top:-8px;"><span>&times;</span></button>
            </div>
            <div class="modal-body" style="padding:1rem 1.5rem;">
                <div id="modalAlert"></div>
                <form id="areaForm">
                    <div class="modal-section">
                        <div class="modal-section-title"><i class="la la-info-circle"></i> Informações</div>
                        <div class="form-group mb-2">
                            <label>Nome <span class="text-danger">*</span></label>
                            <input type="text" id="fName" class="form-control" placeholder="Ex: Fábrica SP, Linha 1, Posto A..." required />
                        </div>
                        <div class="form-group mb-2">
                            <label>Descrição</label>
                            <input type="text" id="fDesc" class="form-control" placeholder="Descrição opcional" />
                        </div>
                        <div class="form-group mb-2">
                            <label>Planta Pai</label>
                            <select id="fParent" class="form-control">
                                <option value="">Nenhuma (planta raiz)</option>
                            </select>
                            <small class="text-muted">Selecione a planta à qual esta pertence, ou deixe vazio para criar uma planta raiz.</small>
                        </div>
                        <div id="hierarchyPreview" class="hierarchy-preview mt-2" style="display:none;">
                            <i class="la la-sitemap"></i> <strong>Hierarquia:</strong> <span id="hierarchyPath"></span>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="padding:.75rem 1.5rem 1.25rem;">
                <button type="button" class="btn btn-light" data-dismiss="modal" style="border-radius:6px;">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSave" style="border-radius:6px;padding:6px 24px;">
                    <i class="la la-check"></i> <span id="btnSaveText">Cadastrar</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content" style="border:none;border-radius:12px;overflow:hidden;">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:700;">Confirmar Exclusão</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <p>Deseja realmente excluir a planta <strong id="deleteNameLabel"></strong>?</p>
                <p class="text-muted small">Essa ação não pode ser desfeita. Plantas com sub-plantas não podem ser excluídas.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-dismiss="modal" style="border-radius:6px;">Cancelar</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete" style="border-radius:6px;">
                    <i class="ft-trash-2"></i> Excluir
                </button>
            </div>
        </div>
    </div>
</div>

<script src="js/areas.js" suppress-error="BL9992"></script>

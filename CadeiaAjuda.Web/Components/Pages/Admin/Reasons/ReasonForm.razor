@page "/register/reasons/new"
@page "/register/reasons/edit/{Id:guid}"
@inject ReasonApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Navigation

<PageTitle>@(isEdit ? "Editar Motivo" : "Novo Motivo") - AssistChain</PageTitle>

<section>
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">@(isEdit ? "Editar Motivo" : "Novo Motivo")</h4>
                </div>
                <div class="card-content">
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible mb-2" role="alert">
                                <button type="button" class="close" @onclick="() => errorMessage = null"><span>&times;</span></button>
                                <i class="la la-warning"></i> @errorMessage
                            </div>
                        }

                        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="reasonForm">
                            <DataAnnotationsValidator />

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Nome <span class="text-danger">*</span></label>
                                        <InputText @bind-Value="model.Name" class="form-control" placeholder="Nome do motivo" />
                                        <ValidationMessage For="() => model.Name" />
                                    </div>
                                </div>
                                @if (isEdit)
                                {
                                    <div class="col-md-2">
                                        <div class="form-group">
                                            <label>Status</label>
                                            <InputSelect @bind-Value="model.ActiveValue" class="form-control">
                                                <option value="true">Ativo</option>
                                                <option value="false">Inativo</option>
                                            </InputSelect>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label>Descrição</label>
                                        <InputTextArea @bind-Value="model.Description" class="form-control" rows="3" placeholder="Descrição do motivo (opcional)" />
                                    </div>
                                </div>
                            </div>

                            <div class="form-actions text-right mt-2">
                                <NavLink href="/register/reasons" class="btn btn-secondary mr-1">
                                    <i class="ft-x"></i> Cancelar
                                </NavLink>
                                <button type="submit" class="btn btn-warning" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <i class="la la-spinner la-spin"></i>
                                    }
                                    <i class="la la-check"></i> @(isEdit ? "Salvar Alterações" : "Cadastrar")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    [SupplyParameterFromForm]
    private ReasonFormModel model { get; set; } = new();
    private bool isEdit => Id.HasValue;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var currentUser = Auth.GetCurrentUser();
        if (currentUser is not null)
        {
            var canManage = currentUser.UserType == UserType.Administrator || currentUser.Permissions.Contains("reasons.manage");
            if (!canManage)
            {
                Navigation.NavigateTo("/register/reasons");
                return;
            }
            model.TenantId = currentUser.TenantId;
            model.SelectedTenantId = currentUser.TenantId.ToString();
        }

        if (isEdit && string.IsNullOrEmpty(model.Name))
        {
            var reason = await Api.GetByIdAsync(Id!.Value);
            if (reason is not null)
            {
                model = new ReasonFormModel
                {
                    Name = reason.Name,
                    Description = reason.Description,
                    SelectedTenantId = reason.TenantId.ToString(),
                    TenantId = reason.TenantId,
                    ActiveValue = reason.Active.ToString().ToLower()
                };
            }
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = null;

        var currentUser = Auth.GetCurrentUser();
        if (currentUser is null)
        {
            errorMessage = "Sessão expirada. Faça login novamente.";
            isSaving = false;
            return;
        }

        if (currentUser.UserType != UserType.Administrator && !currentUser.Permissions.Contains("reasons.manage"))
        {
            errorMessage = "Sem permissão para gerenciar motivos.";
            isSaving = false;
            return;
        }

        model.TenantId = currentUser.TenantId;
        model.SelectedTenantId = currentUser.TenantId.ToString();
        model.Active = bool.TryParse(model.ActiveValue, out var active) ? active : true;

        HttpResponseMessage response;

        if (isEdit)
        {
            response = await Api.UpdateAsync(Id!.Value, model);
        }
        else
        {
            response = await Api.CreateAsync(model);
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/register/reasons");
        }
        else
        {
            try
            {
                var body = await response.Content.ReadAsStringAsync();
                var error = System.Text.Json.JsonSerializer.Deserialize<ErrorResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                errorMessage = error?.Error ?? "Ocorreu um erro ao salvar.";
            }
            catch
            {
                errorMessage = "Ocorreu um erro ao salvar.";
            }
        }

        isSaving = false;
    }

    private class ErrorResponse
    {
        public string? Error { get; set; }
    }
}
